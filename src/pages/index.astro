---
import Layout from "../layouts/Layout.astro";
import type { Note, LinkItem, ActivityLog } from "../utils/db";
import { env } from "cloudflare:workers";
import { formatCategoryName } from "../utils/categories";
import BentoCard from "../components/BentoCard.astro";
import Icon from "../components/Icon.astro";

const user = Astro.locals.user;
const db = env.DB;

if (!user || !db) return Astro.redirect("/login");

const stats = { totalNotes: 0, pinnedNotes: 0, favoriteNotes: 0, storageUsedBytes: 0 };
try {
  const notesCount: any = await db.prepare("SELECT COUNT(id) as count FROM notes WHERE user_id = ?").bind(user.id).first();
  stats.totalNotes = notesCount?.count || 0;
  const pinnedCount: any = await db.prepare("SELECT COUNT(id) as count FROM notes WHERE user_id = ? AND is_pinned = 1").bind(user.id).first();
  stats.pinnedNotes = pinnedCount?.count || 0;
  const favoriteCount: any = await db.prepare("SELECT COUNT(id) as count FROM notes WHERE user_id = ? AND is_favorite = 1").bind(user.id).first();
  stats.favoriteNotes = favoriteCount?.count || 0;
  const sizeSum: any = await db.prepare("SELECT SUM(file_size) as total_size FROM attachments a JOIN notes n ON a.note_id = n.id WHERE n.user_id = ?").bind(user.id).first();
  stats.storageUsedBytes = sizeSum?.total_size || 0;
} catch (e) { console.error("Failed to load stats:", e); }

const formatBytes = (bytes: number) => {
  if (bytes === 0) return "0 B";
  const k = 1024;
  const sizes = ["B", "KB", "MB", "GB"];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + " " + sizes[i];
};

let recentNotes: any[] = [];
let pinnedNotes: any[] = [];
let favoriteNotes: any[] = [];
let watchProgressVideos: (LinkItem & { note_title: string })[] = [];
let activityLogs: ActivityLog[] = [];
let topTags: { name: string; count: number }[] = [];

try {
  const q = `SELECT n.*,(SELECT COUNT(*) FROM attachments a WHERE a.note_id = n.id) as attachment_count,(SELECT mime_type FROM attachments a WHERE a.note_id = n.id LIMIT 1) as first_attachment_mime,(SELECT COUNT(*) FROM links l WHERE l.note_id = n.id) as link_count,(SELECT type FROM links l WHERE l.note_id = n.id LIMIT 1) as first_link_type FROM notes n WHERE n.user_id = ?`;
  const { results: r1 } = await db.prepare(`${q} ORDER BY n.updated_at DESC LIMIT 4`).bind(user.id).all();
  recentNotes = r1;
  const { results: r2 } = await db.prepare(`${q} AND n.is_pinned = 1 ORDER BY n.updated_at DESC LIMIT 4`).bind(user.id).all();
  pinnedNotes = r2;
  const { results: r3 } = await db.prepare(`${q} AND n.is_favorite = 1 ORDER BY n.updated_at DESC LIMIT 4`).bind(user.id).all();
  favoriteNotes = r3;
  const { results: r4 } = await db.prepare("SELECT l.*, n.title as note_title FROM links l JOIN notes n ON l.note_id = n.id WHERE n.user_id = ? AND l.type = 'youtube' AND l.watch_progress > 0 ORDER BY l.created_at DESC LIMIT 4").bind(user.id).all<LinkItem & { note_title: string }>();
  watchProgressVideos = r4;
  const { results: r5 } = await db.prepare("SELECT * FROM activity_logs WHERE user_id = ? ORDER BY created_at DESC LIMIT 5").bind(user.id).all<ActivityLog>();
  activityLogs = r5;
  const { results: r6 } = await db.prepare("SELECT t.name, COUNT(nt.note_id) as count FROM tags t JOIN note_tags nt ON t.id = nt.tag_id JOIN notes n ON nt.note_id = n.id WHERE n.user_id = ? GROUP BY t.name ORDER BY count DESC LIMIT 8").bind(user.id).all<{ name: string; count: number }>();
  topTags = r6;
} catch (e) { console.error("Failed to load dashboard data:", e); }

const getIconName = (note: any) => {
  if (note.attachment_count > 0) return note.first_attachment_mime === "application/pdf" ? "file-text" : "image";
  if (note.link_count > 0) return note.first_link_type === "youtube" ? "video" : note.first_link_type === "drive" ? "folder" : "link";
  return "file";
};

const getActivityIcon = (action: string) => {
  if (action.includes("note")) return "file-text";
  if (action.includes("collection")) return "folder";
  if (action.includes("file") || action.includes("upload")) return "paperclip";
  if (action.includes("login") || action.includes("auth")) return "key";
  return "zap";
};
---

<Layout title="Dashboard - PoraHobe">
  <div class="flex flex-col gap-6 max-w-[1200px] mx-auto animate-[fadeIn_0.4s_cubic-bezier(0.16,1,0.3,1)_forwards]">
    <BentoCard interactive={false} class="flex justify-between items-center bg-gradient-to-br from-[var(--accent-primary)] to-[var(--accent-secondary)] text-white !border-white/10 shadow-[0_8px_32px_rgba(139,92,246,0.15)]">
      <div>
        <h2 class="text-[1.8rem] font-bold tracking-tight mb-1 text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.1)]">
          Welcome back, {user.username}!
          <Icon name="sparkles" size={20} class="text-[var(--warning)] inline-block align-middle ml-1" />
        </h2>
        <p class="text-white/90 text-base">Your workspace is synced and ready. Here is a summary of your shared study materials and indexed resources.</p>
      </div>
      <div class="flex gap-3 shrink-0">
        <a href="/notes/new" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 border border-white/25 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer text-white transition-all duration-[var(--transition-fast)] hover:bg-white hover:text-[var(--accent-primary)] hover:border-white hover:-translate-y-0.5">
          <Icon name="plus" size={20} />
          <span>Share Material</span>
        </a>
        <button id="dash-create-folder-btn" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 border border-white/25 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer text-white transition-all duration-[var(--transition-fast)] hover:bg-white hover:text-[var(--accent-primary)] hover:border-white hover:-translate-y-0.5">
          <Icon name="folder" size={20} />
          <span>New Folder</span>
        </button>
      </div>
    </BentoCard>

    <div class="grid grid-cols-12 gap-5 max-lg:flex max-lg:flex-col">
      <BentoCard class="col-span-4 max-lg:col-span-full bg-[radial-gradient(circle_at_top_left,var(--accent-glow)_0%,var(--card-bg)_100%)]">
        <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider">Storage & Stats</h3>
        <div class="grid grid-cols-2 gap-3 mt-4">
          {[
            { label: "Total Materials", value: stats.totalNotes },
            { label: "Pinned Items", value: stats.pinnedNotes },
            { label: "Bookmarks", value: stats.favoriteNotes },
            { label: "S3 Storage", value: formatBytes(stats.storageUsedBytes) },
          ].map((item) => (
            <div class="flex flex-col gap-1 bg-[var(--bg-primary)] p-4 rounded-[var(--border-radius-md)] border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] hover:border-[var(--accent-primary)] hover:shadow-[var(--shadow-sm)] hover:-translate-y-px">
              <span class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">{item.label}</span>
              <span class="text-[1.75rem] font-bold text-[var(--text-primary)] mt-1">{item.value}</span>
            </div>
          ))}
        </div>
      </BentoCard>

      <BentoCard class="col-span-8 max-lg:col-span-full">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider">Pinned Resources</h3>
          <a href="/notes?is_pinned=1" class="text-sm font-semibold text-[var(--accent-primary)] hover:opacity-80">View all</a>
        </div>
        {pinnedNotes.length === 0 ? (
          <div class="p-8 text-center text-sm text-[var(--text-muted)] italic bg-[var(--bg-secondary)] border border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] w-full">No pinned resources yet. Pin items inside their page to keep them handy here.</div>
        ) : (
          <div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
            {pinnedNotes.map((note) => (
              <a href={`/notes/${note.id}`} class="flex items-center gap-3 p-4 bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--accent-primary)] hover:shadow-[var(--shadow-md)] hover:-translate-y-0.5 no-underline">
                <span class="w-[42px] h-[42px] bg-[var(--bg-primary)] border border-[var(--card-border)] rounded-lg flex items-center justify-center shrink-0 shadow-[var(--shadow-sm)]">
                  <Icon name={getIconName(note)} size={18} />
                </span>
                <div class="flex flex-col min-w-0 flex-1">
                  <span class="font-semibold text-sm text-[var(--text-primary)] truncate">{note.title}</span>
                  <span class="text-xs text-[var(--text-muted)] mt-0.5">{formatCategoryName(note.category) || "General"} • {note.semester || "All"}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </BentoCard>

      <BentoCard class="col-span-6 max-lg:col-span-full">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider">Recent Materials</h3>
          <a href="/notes" class="text-sm font-semibold text-[var(--accent-primary)] hover:opacity-80">View all</a>
        </div>
        {recentNotes.length === 0 ? (
          <div class="p-8 text-center text-sm text-[var(--text-muted)] italic bg-[var(--bg-secondary)] border border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] w-full">No study materials shared yet. Share your first resource to get started!</div>
        ) : (
          <ul class="flex flex-col gap-2 list-none">
            {recentNotes.map((note) => (
              <li>
                <a href={`/notes/${note.id}`} class="flex justify-between items-center px-4 py-3 rounded-[var(--border-radius-md)] bg-[var(--bg-secondary)] border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--accent-primary)] hover:shadow-[var(--shadow-sm)] hover:translate-x-0.5">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-7 h-7 bg-[var(--bg-primary)] border border-[var(--card-border)] rounded-md flex items-center justify-center shrink-0">
                      <Icon name={getIconName(note)} size={15} />
                    </span>
                    <span class="text-sm font-medium text-[var(--text-primary)] truncate max-w-[240px]">{note.title}</span>
                  </div>
                  <span class="text-xs text-[var(--text-muted)] font-medium">{new Date(note.updated_at).toLocaleDateString()}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </BentoCard>

      <BentoCard class="col-span-6 max-lg:col-span-full">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider">Bookmarked Resources</h3>
          <a href="/notes?is_favorite=1" class="text-sm font-semibold text-[var(--accent-primary)] hover:opacity-80">View all</a>
        </div>
        {favoriteNotes.length === 0 ? (
          <div class="p-8 text-center text-sm text-[var(--text-muted)] italic bg-[var(--bg-secondary)] border border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] w-full">No bookmarks marked. Star resources inside their details view to see them here.</div>
        ) : (
          <ul class="flex flex-col gap-2 list-none">
            {favoriteNotes.map((note) => (
              <li>
                <a href={`/notes/${note.id}`} class="flex justify-between items-center px-4 py-3 rounded-[var(--border-radius-md)] bg-[var(--bg-secondary)] border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--accent-primary)] hover:shadow-[var(--shadow-sm)] hover:translate-x-0.5">
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="w-7 h-7 bg-[var(--bg-primary)] border border-[var(--card-border)] rounded-md flex items-center justify-center shrink-0">
                      <Icon name={getIconName(note)} size={15} />
                    </span>
                    <span class="text-sm font-medium text-[var(--text-primary)] truncate max-w-[240px]">{note.title}</span>
                  </div>
                  <span class="text-xs text-[var(--text-muted)] bg-[var(--accent-glow)] text-[var(--accent-primary)] px-2 py-0.5 rounded-[var(--border-radius-full)] border border-[hsla(262,83%,58%,0.1)] font-medium">{formatCategoryName(note.category) || "General"}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </BentoCard>

      <BentoCard class="col-span-6 max-lg:col-span-full">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider">Recently Watched Videos</h3>
          <a href="/notes/history" class="text-sm font-semibold text-[var(--accent-primary)] hover:opacity-80">View all</a>
        </div>
        {watchProgressVideos.length === 0 ? (
          <div class="p-8 text-center text-sm text-[var(--text-muted)] italic bg-[var(--bg-secondary)] border border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] w-full">No video watch progress found. Embed YouTube videos inside notes.</div>
        ) : (
          <div class="grid grid-cols-2 gap-4 max-sm:grid-cols-1">
            {watchProgressVideos.map((video) => {
              const videoId = video.thumbnail_url?.split("/vi/")[1]?.split("/")[0] || "";
              const mins = Math.floor(video.watch_progress / 60);
              const secs = video.watch_progress % 60;
              return (
                <a href={`/notes/${video.note_id}`} class="flex flex-col gap-2.5 bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] p-3 transition-all duration-[var(--transition-fast)] hover:border-[var(--accent-primary)] hover:shadow-[var(--shadow-md)] hover:-translate-y-0.5 no-underline">
                  <div class="relative aspect-video rounded-[var(--border-radius-sm)] overflow-hidden bg-black">
                    {video.thumbnail_url ? (
                      <img src={video.thumbnail_url} alt={video.title || "Video"} loading="lazy" class="w-full h-full object-cover transition-transform duration-[var(--transition-normal)] group-hover:scale-105" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-[var(--text-muted)] bg-gradient-to-br from-[var(--bg-secondary)] to-[var(--bg-tertiary)]">
                        <Icon name="video" size={24} />
                      </div>
                    )}
                    <span class="absolute bottom-2 right-2 bg-black/85 backdrop-blur-[4px] text-white text-[0.7rem] font-semibold px-2 py-0.5 rounded border border-white/15">{mins}m {secs}s</span>
                  </div>
                  <div class="flex flex-col gap-0.5 min-w-0">
                    <span class="text-sm font-semibold text-[var(--text-primary)] truncate">{video.title || "YouTube Video"}</span>
                    <span class="text-xs text-[var(--text-muted)] truncate">In: {video.note_title}</span>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </BentoCard>

      <BentoCard class="col-span-6 max-lg:col-span-full">
        <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-4">Activity Timeline</h3>
        {activityLogs.length === 0 ? (
          <div class="p-8 text-center text-sm text-[var(--text-muted)] italic bg-[var(--bg-secondary)] border border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] w-full">No logs recorded. Activity shows up as you interact.</div>
        ) : (
          <div class="flex flex-col gap-4 relative pl-5 before:content-[''] before:absolute before:top-1 before:left-[6px] before:bottom-1 before:w-[2px] before:bg-[var(--card-border)]">
            {activityLogs.map((log) => {
              const diffMs = Date.now() - log.created_at;
              const diffMins = Math.floor(diffMs / 60000);
              let timeStr = "just now";
              if (diffMins > 0 && diffMins < 60) timeStr = `${diffMins}m ago`;
              else if (diffMins >= 60 && diffMins < 1440) timeStr = `${Math.floor(diffMins / 60)}h ago`;
              else if (diffMins >= 1440) timeStr = `${Math.floor(diffMins / 1440)}d ago`;
              return (
                <div class="flex gap-3.5 relative">
                  <span class="flex items-center justify-center w-[26px] h-[26px] bg-[var(--bg-primary)] border border-[var(--card-border)] rounded-full shrink-0 z-1 absolute -left-[26px] top-0">
                    <Icon name={getActivityIcon(log.action)} size={14} />
                  </span>
                  <div class="flex flex-col gap-0.5 min-w-0 flex-1 pl-2">
                    <p class="text-sm font-medium text-[var(--text-secondary)] leading-relaxed">{log.details}</p>
                    <span class="text-xs text-[var(--text-muted)]">{timeStr}</span>
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </BentoCard>

      <BentoCard class="col-span-12 max-lg:col-span-full">
        <h3 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider">Workspace Tags</h3>
        {topTags.length === 0 ? (
          <div class="p-8 text-center text-sm text-[var(--text-muted)] italic bg-[var(--bg-secondary)] border border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] w-full mt-3">No tags created. Add tags when editing notes to categorize.</div>
        ) : (
          <div class="flex flex-wrap gap-2 mt-3">
            {topTags.map((tag) => (
              <a href={`/notes?tag=${encodeURIComponent(tag.name)}`} class="inline-flex items-center gap-1.5 bg-[var(--bg-secondary)] border border-[var(--card-border)] px-3 py-1.5 rounded-[var(--border-radius-full)] text-sm transition-all duration-[var(--transition-fast)] cursor-pointer hover:bg-[var(--accent-glow)] hover:border-[var(--accent-primary)] hover:-translate-y-px no-underline">
                <span class="text-[var(--text-muted)] font-semibold">#</span>
                <span class="text-[var(--text-secondary)] font-medium hover:text-[var(--accent-primary)]">{tag.name}</span>
                <span class="bg-[var(--bg-tertiary)] text-[var(--text-muted)] text-[0.7rem] px-1.5 py-0.5 rounded-[var(--border-radius-full)] font-semibold transition-all duration-[var(--transition-fast)] group-hover:bg-[var(--accent-primary)] group-hover:text-white">{tag.count}</span>
              </a>
            ))}
          </div>
        )}
      </BentoCard>
    </div>
  </div>

  <script>
    const dashFolderBtn = document.getElementById("dash-create-folder-btn");
    if (dashFolderBtn) {
      dashFolderBtn.addEventListener("click", async () => {
        const name = prompt("Enter new folder name:");
        if (name && name.trim()) {
          try {
            const res = await fetch("/api/collections", {
              method: "POST", headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ name: name.trim() }),
            });
            if (res.ok) window.location.reload();
            else { const data = await res.json(); alert(data.error || "Failed to create folder"); }
          } catch (err) { console.error(err); }
        }
      });
    }
  </script>
</Layout>
