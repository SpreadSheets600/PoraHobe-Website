---
import Layout from '../../layouts/Layout.astro';
import type { Note } from '../../utils/db';
import { env } from 'cloudflare:workers';
import { formatCategoryName } from '../../utils/categories';
import BentoCard from '../../components/BentoCard.astro';
import NoteCard from '../../components/NoteCard.astro';
import Icon from '../../components/Icon.astro';

const user = Astro.locals.user;
const db = env.DB;

if (!user || !db) return Astro.redirect('/login');

const url = Astro.url;
const search = url.searchParams.get('search') || '';
const collectionId = url.searchParams.get('collection_id') || '';
const tag = url.searchParams.get('tag') || '';
const categoryFilter = url.searchParams.get('category') || '';
const semesterFilter = url.searchParams.get('semester') || '';
const isFavorite = url.searchParams.get('is_favorite') === '1';
const isPinned = url.searchParams.get('is_pinned') === '1';
const sort = url.searchParams.get('sort') || 'updated_desc';

let categories: string[] = [];
let semesters: string[] = [];
try {
  const catRes = await db.prepare('SELECT DISTINCT category FROM notes WHERE user_id = ? AND category IS NOT NULL AND category != ""').bind(user.id).all();
  categories = catRes.results.map((r: any) => r.category);
  const semRes = await db.prepare('SELECT DISTINCT semester FROM notes WHERE user_id = ? AND semester IS NOT NULL AND semester != ""').bind(user.id).all();
  semesters = semRes.results.map((r: any) => r.semester);
} catch (e) { console.error('Failed to load filter items:', e); }

let query = `
  SELECT n.*, c.name as collection_name,
  (SELECT group_concat(t.name) FROM note_tags nt JOIN tags t ON nt.tag_id = t.id WHERE nt.note_id = n.id) as tags,
  (SELECT COUNT(*) FROM attachments a WHERE a.note_id = n.id) as attachment_count,
  (SELECT mime_type FROM attachments a WHERE a.note_id = n.id LIMIT 1) as first_attachment_mime,
  (SELECT COUNT(*) FROM links l WHERE l.note_id = n.id) as link_count,
  (SELECT type FROM links l WHERE l.note_id = n.id LIMIT 1) as first_link_type
  FROM notes n LEFT JOIN collections c ON n.collection_id = c.id WHERE n.user_id = ?
`;
const params: any[] = [user.id];

if (collectionId) {
  if (collectionId === 'root') query += ' AND n.collection_id IS NULL';
  else { query += ' AND n.collection_id = ?'; params.push(collectionId); }
}
if (search) { query += ' AND (n.title LIKE ? OR n.content LIKE ?)'; params.push(`%${search}%`, `%${search}%`); }
if (tag) { query += ` AND n.id IN (SELECT nt.note_id FROM note_tags nt JOIN tags t ON nt.tag_id = t.id WHERE t.name = ?)`; params.push(tag.toLowerCase()); }
if (categoryFilter) { query += ' AND n.category = ?'; params.push(categoryFilter); }
if (semesterFilter) { query += ' AND n.semester = ?'; params.push(semesterFilter); }
if (isFavorite) query += ' AND n.is_favorite = 1';
if (isPinned) query += ' AND n.is_pinned = 1';

if (sort === 'updated_desc') query += ' ORDER BY n.is_pinned DESC, n.updated_at DESC';
else if (sort === 'updated_asc') query += ' ORDER BY n.updated_at ASC';
else if (sort === 'title_asc') query += ' ORDER BY n.title ASC';
else if (sort === 'title_desc') query += ' ORDER BY n.title DESC';
else if (sort === 'created_desc') query += ' ORDER BY n.created_at DESC';

let notes: any[] = [];
try {
  const { results } = await db.prepare(query).bind(...params).all();
  notes = results.map((r: any) => ({
    ...r, tags: r.tags ? r.tags.split(',') : [], is_favorite: !!r.is_favorite, is_pinned: !!r.is_pinned,
    attachment_count: r.attachment_count || 0, first_attachment_mime: r.first_attachment_mime || '',
    link_count: r.link_count || 0, first_link_type: r.first_link_type || '',
  }));
} catch (e) { console.error('Failed to load notes list:', e); }

let currentCollectionName = '';
if (collectionId && collectionId !== 'root') {
  try {
    const col: any = await db.prepare('SELECT name FROM collections WHERE id = ? AND user_id = ?').bind(collectionId, user.id).first();
    currentCollectionName = col?.name || '';
  } catch (e) { console.error('Failed to load collection details:', e); }
}
---

<Layout title="Notes Archive - PoraHobe">
  <div class="max-w-[1200px] mx-auto flex flex-col gap-6 animate-[fadeIn_0.4s_cubic-bezier(0.16,1,0.3,1)_forwards]">
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-3">
        <h2 class="text-[1.5rem] font-bold tracking-tight">
          {collectionId && currentCollectionName ? `Folder: ${currentCollectionName}` : 'All Study Material'}
          {tag && ` #${tag}`}
          {isFavorite && ' ★ Bookmarks'}
          {isPinned && ' 📌 Pinned'}
        </h2>
        <p class="text-sm text-[var(--text-muted)]">{notes.length} resource{notes.length === 1 ? '' : 's'} found</p>
      </div>

      <BentoCard class="grid grid-cols-4 max-md:grid-cols-2 max-sm:grid-cols-1 gap-4 !px-6 !py-4" padding>
        {[
          { id: 'filter-search', type: 'text', value: search, placeholder: 'Filter titles & body...', label: 'Search text' },
        ].map((f) => (
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">{f.label}</label>
            <input type={f.type} id={f.id} value={f.value} placeholder={f.placeholder} class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3 py-2 text-sm text-[var(--text-primary)] cursor-pointer transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" />
          </div>
        ))}
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Category</label>
          <select id="filter-category" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3 py-2 text-sm text-[var(--text-primary)] cursor-pointer transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
            <option value="">All Categories</option>
            {categories.map((cat) => (<option value={cat} selected={cat === categoryFilter}>{cat}</option>))}
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Semester</label>
          <select id="filter-semester" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3 py-2 text-sm text-[var(--text-primary)] cursor-pointer transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
            <option value="">All Semesters</option>
            {semesters.map((sem) => (<option value={sem} selected={sem === semesterFilter}>{sem}</option>))}
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Sort By</label>
          <select id="filter-sort" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3 py-2 text-sm text-[var(--text-primary)] cursor-pointer transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
            <option value="updated_desc" selected={sort === 'updated_desc'}>Recently Updated</option>
            <option value="created_desc" selected={sort === 'created_desc'}>Recently Created</option>
            <option value="title_asc" selected={sort === 'title_asc'}>Title A-Z</option>
            <option value="title_desc" selected={sort === 'title_desc'}>Title Z-A</option>
          </select>
        </div>
      </BentoCard>
    </div>

    {notes.length === 0 ? (
      <BentoCard class="flex flex-col items-center gap-3 py-12 text-center">
        <Icon name="file-text" size={48} class="text-[var(--text-muted)]" />
        <h3 class="text-lg font-semibold">No materials match your filters</h3>
        <p class="text-sm text-[var(--text-muted)]">Try clearing your search query or choosing another folder.</p>
        <a href="/notes/new" class="inline-flex items-center justify-center gap-2 px-[18px] py-2.5 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] hover:-translate-y-px mt-3">Create New Note</a>
      </BentoCard>
    ) : (
      <div class="grid grid-cols-12 gap-5 max-lg:flex max-lg:flex-col">
        {notes.map((note) => <NoteCard note={note} />)}
      </div>
    )}
  </div>

  <script>
    const searchInput = document.getElementById('filter-search') as HTMLInputElement;
    const categorySelect = document.getElementById('filter-category') as HTMLSelectElement;
    const semesterSelect = document.getElementById('filter-semester') as HTMLSelectElement;
    const sortSelect = document.getElementById('filter-sort') as HTMLSelectElement;

    const applyFilters = () => {
      const url = new URL(window.location.href);
      if (searchInput.value.trim()) url.searchParams.set('search', searchInput.value.trim());
      else url.searchParams.delete('search');
      if (categorySelect.value) url.searchParams.set('category', categorySelect.value);
      else url.searchParams.delete('category');
      if (semesterSelect.value) url.searchParams.set('semester', semesterSelect.value);
      else url.searchParams.delete('semester');
      if (sortSelect.value) url.searchParams.set('sort', sortSelect.value);
      else url.searchParams.delete('sort');
      window.location.href = url.pathname + url.search;
    };

    categorySelect?.addEventListener('change', applyFilters);
    semesterSelect?.addEventListener('change', applyFilters);
    sortSelect?.addEventListener('change', applyFilters);
    searchInput?.addEventListener('keypress', (e) => { if (e.key === 'Enter') applyFilters(); });
  </script>
</Layout>
