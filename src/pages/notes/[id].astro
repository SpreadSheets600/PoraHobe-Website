  <!-- Marked and KaTeX for client-side math and markdown parsing -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js" is:inline></script>

  <script>
    const noteViewWrapper = document.getElementById('note-view-wrapper') as HTMLDivElement;
    const noteId = noteViewWrapper?.dataset.noteId;

    const readPane = document.getElementById('read-pane');
    const editPane = document.getElementById('edit-pane');
    const editModeBtn = document.getElementById('edit-mode-btn');
    const cancelEditBtn = document.getElementById('cancel-edit-btn');
    const saveEditBtn = document.getElementById('save-edit-btn');

    // Title & Content Inputs for edit mode
    const editTitleInput = document.getElementById('edit-title-input') as HTMLInputElement;
    const editContentInput = document.getElementById('edit-content-input') as HTMLTextAreaElement;
    const editCategoryInput = document.getElementById('edit-category-input') as HTMLInputElement;
    const editSemesterInput = document.getElementById('edit-semester-input') as HTMLInputElement;
    const editTopicInput = document.getElementById('edit-topic-input') as HTMLInputElement;
    const editTagsInput = document.getElementById('edit-tags-input') as HTMLInputElement;

    // View content target
    const viewTitleText = document.getElementById('note-view-title');
    const viewBodyRendered = document.getElementById('note-body-rendered');

    // Rendering content helper (runs on client)
    const renderContent = (markdownText: string) => {
      if (!viewBodyRendered) return;

      // 1. Markdown
      // @ts-ignore
      let html = typeof marked !== 'undefined' ? marked.parse(markdownText) : markdownText;

      // 2. LaTeX Display Math
      html = html.replace(/\$\$([\s\S]*?)\$\$/g, (match: string, equation: string) => {
        try {
          // @ts-ignore
          return `<div class="math-display">${katex.renderToString(equation, { displayMode: true, throwOnError: false })}</div>`;
        } catch (e) {
          return match;
        }
      });

      // 3. LaTeX Inline Math
      html = html.replace(/\$([^$\n]+?)\$/g, (match: string, equation: string) => {
        try {
          // @ts-ignore
          return `<span class="math-inline">${katex.renderToString(equation, { displayMode: false, throwOnError: false })}</span>`;
        } catch (e) {
          return match;
        }
      });

      // 4. Wrap naked timestamps inside a link for YT video seek logic
      // Matches 1:05, 12:45, 1:23:45
      html = html.replace(/\b(\d{1,2}:)?(\d{1,2}):(\d{2})\b/g, (match: string) => {
        const parts = match.split(':').map(Number);
        let seconds = 0;
        if (parts.length === 3) {
          seconds = parts[0] * 3600 + parts[1] * 60 + parts[2];
        } else if (parts.length === 2) {
          seconds = parts[0] * 60 + parts[1];
        }
        return `<a href="#" class="youtube-timestamp" data-seconds="${seconds}">${match}</a>`;
      });

      viewBodyRendered.innerHTML = html;

      // Bind click triggers for timestamps
      const tsLinks = viewBodyRendered.querySelectorAll('.youtube-timestamp');
      tsLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const secs = Number((link as HTMLElement).dataset.seconds);
          seekActiveVideos(secs);
        });
      });

    };

    // Preview Hub Tabs toggle logic
    const previewTabs = document.querySelectorAll('.preview-tab-btn');
    const previewPanes = document.querySelectorAll('.preview-pane-content');

    if (previewTabs.length > 0) {
      previewTabs[0].classList.add('active');
      const firstTargetId = (previewTabs[0] as HTMLElement).dataset.targetId;
      if (firstTargetId) {
        document.getElementById(firstTargetId)?.classList.remove('hidden');
      }

      previewTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          previewTabs.forEach((t) => t.classList.remove('active'));
          previewPanes.forEach((p) => p.classList.add('hidden'));

          tab.classList.add('active');
          const targetId = (tab as HTMLElement).dataset.targetId;
          if (targetId) {
            document.getElementById(targetId)?.classList.remove('hidden');
          }
        });
      });
    }

    // Run first render on page load
    if (editContentInput) {
      renderContent(editContentInput.value);
    }

    // Toggle Edit Mode Panel (Split View)
    editModeBtn?.addEventListener('click', () => {
      const isEditing = noteViewWrapper.classList.toggle('editing');
      editPane?.classList.toggle('hidden');
      
      if (isEditing) {
        editModeBtn.classList.add('active');
        editContentInput.focus();
      } else {
        editModeBtn.classList.remove('active');
      }
    });

    cancelEditBtn?.addEventListener('click', () => {
      noteViewWrapper.classList.remove('editing');
      editPane?.classList.add('hidden');
      editModeBtn?.classList.remove('active');
      
      // Reset input values
      if (editTitleInput) editTitleInput.value = viewTitleText?.textContent || '';
    });

    // Save Edit Panel changes
    saveEditBtn?.addEventListener('click', async () => {
      const title = editTitleInput.value.trim();
      const content = editContentInput.value;
      const category = editCategoryInput.value.trim();
      const semester = editSemesterInput.value.trim();
      const topic = editTopicInput.value.trim();
      const tagsString = editTagsInput.value;

      if (!title) {
        alert('Title is required');
        return;
      }

      const tags = tagsString
        .split(',')
        .map((t) => t.trim())
        .filter((t) => t.length > 0);

      try {
        saveEditBtn.setAttribute('disabled', 'true');
        saveEditBtn.textContent = 'Saving...';

        const res = await fetch(`/api/notes/${noteId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title,
            content,
            category,
            semester,
            topic,
            tags,
          }),
        });

        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          alert(data.error || 'Failed to update note');
        }
      } catch (e) {
        console.error(e);
        alert('Failed to save changes');
      } finally {
        saveEditBtn.removeAttribute('disabled');
        saveEditBtn.textContent = 'Save Changes';
      }
    });

    // Focus Mode Toggle (Distraction Free)
    const focusModeBtn = document.getElementById('focus-mode-btn');
    const focusProgressContainer = document.getElementById('focus-progress-container');
    const focusProgressBar = document.getElementById('focus-progress');

    focusModeBtn?.addEventListener('click', () => {
      const isFocus = document.body.classList.toggle('focus-active');
      focusModeBtn.classList.toggle('active');
      
      if (isFocus) {
        focusProgressContainer!.style.display = 'block';
        
        // Add scroll listener for progress tracking
        window.addEventListener('scroll', trackingFocusScroll);
        trackingFocusScroll(); // initial trigger
      } else {
        focusProgressContainer!.style.display = 'none';
        window.removeEventListener('scroll', trackingFocusScroll);
      }
    });

    const trackingFocusScroll = () => {
      if (!focusProgressBar) return;
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      focusProgressBar.style.width = scrolled + '%';
    };

    // Bookmark Toggle (Favorite)
    const bookmarkBtn = document.getElementById('bookmark-toggle-btn');
    bookmarkBtn?.addEventListener('click', async () => {
      const isFavorite = bookmarkBtn.classList.toggle('active');
      try {
        await fetch(`/api/notes/${noteId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ is_favorite: isFavorite }),
        });
      } catch (e) {
        console.error(e);
      }
    });

    // Pin Toggle
    const pinBtn = document.getElementById('pin-toggle-btn');
    pinBtn?.addEventListener('click', async () => {
      const isPinned = pinBtn.classList.toggle('active');
      try {
        await fetch(`/api/notes/${noteId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ is_pinned: isPinned }),
        });
      } catch (e) {
        console.error(e);
      }
    });

    // Move Collection (Folder dropdown)
    const moveColSelect = document.getElementById('move-collection-select') as HTMLSelectElement;
    moveColSelect?.addEventListener('change', async () => {
      const colId = moveColSelect.value || null;
      try {
        const res = await fetch(`/api/notes/${noteId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ collection_id: colId }),
        });
        if (!res.ok) alert('Failed to move folder');
      } catch (e) {
        console.error(e);
      }
    });

    // Delete Note
    const deleteBtn = document.getElementById('delete-note-btn');
    deleteBtn?.addEventListener('click', async () => {
      if (confirm('Are you sure you want to delete this study material? This will delete all R2 attachments and YouTube progress links.')) {
        try {
          const res = await fetch(`/api/notes/${noteId}`, { method: 'DELETE' });
          if (res.ok) {
            window.location.href = '/notes';
          } else {
            alert('Failed to delete note');
          }
        } catch (e) {
          console.error(e);
        }
      }
    });

    // Drag and Drop File Upload logic
    const uploadZone = document.getElementById('upload-zone');
    const fileInputField = document.getElementById('file-input-field') as HTMLInputElement;
    const attachmentsList = document.getElementById('attachments-list');
    const emptyAttMsg = document.getElementById('empty-att-msg');

    const handleUploadFiles = async (files: FileList) => {
      if (!files || files.length === 0) return;

      const formatBytesLocal = (bytes: number) => {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
      };

      for (const file of files) {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('noteId', noteId!);

        try {
          // Visual state loading feedback
          const loadingLi = document.createElement('li');
          loadingLi.className = 'attachment-item';
          loadingLi.innerHTML = `<span>⏳ Uploading "${file.name}"...</span>`;
          attachmentsList?.appendChild(loadingLi);
          emptyAttMsg?.classList.add('hidden');

          const res = await fetch('/api/upload', {
            method: 'POST',
            body: formData,
          });

          const data = await res.json();
          loadingLi.remove();

          if (res.ok) {
            const newAtt = data.attachment;
            const li = document.createElement('li');
            li.className = 'attachment-item';
            li.dataset.attId = newAtt.id;
            li.innerHTML = `
              <div class="att-info">
                <a href="/api/files/${newAtt.id}" target="_blank" class="att-name-link" title="Open file">
                  📎 <span class="att-filename">${newAtt.filename}</span>
                </a>
                <span class="att-size">${formatBytesLocal(newAtt.file_size)}</span>
              </div>
              <button class="delete-att-btn" data-att-id="${newAtt.id}">×</button>
            `;
            attachmentsList?.appendChild(li);
            
            // Re-bind delete trigger
            bindDeleteAttachmentBtn(li.querySelector('.delete-att-btn') as HTMLButtonElement);
          } else {
            alert(`Failed to upload ${file.name}: ${data.error}`);
            if (attachmentsList?.children.length === 0) emptyAttMsg?.classList.remove('hidden');
          }
        } catch (e) {
          console.error(e);
          alert('Upload failed due to connection error.');
        }
      }
    };

    // Attach drag & drop triggers
    uploadZone?.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadZone.classList.add('dragover');
    });

    uploadZone?.addEventListener('dragleave', () => {
      uploadZone.classList.remove('dragover');
    });

    uploadZone?.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      const files = e.dataTransfer?.files;
      if (files) handleUploadFiles(files);
    });

    fileInputField?.addEventListener('change', () => {
      const files = fileInputField.files;
      if (files) handleUploadFiles(files);
    });

    // Delete attachment helper
    const bindDeleteAttachmentBtn = (btn: HTMLButtonElement) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const attId = btn.dataset.attId;
        if (confirm('Delete this file?')) {
          try {
            const res = await fetch(`/api/files/${attId}`, { method: 'DELETE' });
            if (res.ok) {
              const li = btn.closest('.attachment-item');
              li?.remove();
              if (attachmentsList?.children.length === 0) {
                emptyAttMsg?.classList.remove('hidden');
              }
            } else {
              alert('Failed to delete file');
            }
          } catch (err) {
            console.error(err);
          }
        }
      });
    };

    // Bind all initial attachment delete triggers
    const initialDeleteBtns = document.querySelectorAll('.delete-att-btn');
    initialDeleteBtns.forEach((btn) => bindDeleteAttachmentBtn(btn as HTMLButtonElement));

    // YouTube API watch progress tracker & seeks timestamps logic
    const ytPlayers = new Map<string, any>();
    const activeVideoContainers = document.querySelectorAll('.youtube-player-container-main');

    // Make YouTube seek functional
    const seekActiveVideos = (seconds: number) => {
      ytPlayers.forEach((player) => {
        try {
          player.seekTo(seconds, true);
          player.playVideo();
        } catch (e) {
          console.error('Failed to seek player:', e);
        }
      });
    };

    // Load YT Player script
    if (activeVideoContainers.length > 0) {
      const tag = document.createElement('script');
      tag.src = "https://www.youtube.com/iframe_api";
      const firstScriptTag = document.getElementsByTagName('script')[0];
      firstScriptTag.parentNode?.insertBefore(tag, firstScriptTag);
    }

    // Global YouTube API Ready Callback
    // @ts-ignore
    window.onYouTubeIframeAPIReady = () => {
      activeVideoContainers.forEach((container) => {
        const linkId = (container as HTMLElement).dataset.linkId;
        const videoId = (container as HTMLElement).dataset.videoId;
        const initialProgress = Number((container as HTMLElement).dataset.progress) || 0;
        const progressText = document.getElementById(`progress-text-main-${linkId}`);

        let lastSavedTime = initialProgress;

        // @ts-ignore
        const player = new YT.Player(`yt-player-main-${linkId}`, {
          height: '100%',
          width: '100%',
          videoId: videoId,
          playerVars: {
            start: initialProgress,
            rel: 0,
            modestbranding: 1
          },
          events: {
            onStateChange: (event: any) => {
              // @ts-ignore
              if (event.data === YT.PlayerState.PAUSED || event.data === YT.PlayerState.ENDED) {
                saveProgress(player.getCurrentTime());
              }
            }
          }
        });

        // Periodically check/save progress (every 5 seconds while playing)
        setInterval(() => {
          try {
            // @ts-ignore
            if (player && player.getPlayerState() === YT.PlayerState.PLAYING) {
              const currentTime = Math.round(player.getCurrentTime());
              if (Math.abs(currentTime - lastSavedTime) >= 5) {
                saveProgress(currentTime);
              }
            }
          } catch (e) {}
        }, 5000);

        const saveProgress = async (currentTime: number) => {
          const roundedTime = Math.round(currentTime);
          lastSavedTime = roundedTime;
          
          if (progressText) {
            const mins = Math.floor(roundedTime / 60);
            const secs = roundedTime % 60;
            progressText.textContent = `Saved progress: ${mins}m ${secs}s`;
          }

          try {
            await fetch('/api/progress', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                linkId: linkId,
                progress: roundedTime
              })
            });
          } catch (e) {
            console.error('Failed to auto save progress:', e);
          }
        };

        ytPlayers.set(linkId!, player);
      });
    };
  </script>
</Layout>
