---
import Layout from '../../layouts/Layout.astro';
import type { Collection } from '../../utils/db';
import { env } from 'cloudflare:workers';
import { formatCategoryName } from '../../utils/categories';

const user = Astro.locals.user;
const db = env.DB;

if (!user || !db) {
  return Astro.redirect('/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/notes');
}

// 1. Fetch Note Details
let note: any = null;
try {
  note = await db
    .prepare(
      `SELECT n.*, c.name as collection_name 
       FROM notes n 
       LEFT JOIN collections c ON n.collection_id = c.id 
       WHERE n.id = ? AND n.user_id = ?`
    )
    .bind(id, user.id)
    .first();
} catch (e) {
  console.error('Error fetching note details:', e);
}

if (!note) {
  return Astro.redirect('/notes');
}

note.is_favorite = !!note.is_favorite;
note.is_pinned = !!note.is_pinned;

// 2. Fetch tags
let tags: string[] = [];
try {
  const { results } = await db
    .prepare('SELECT t.name FROM note_tags nt JOIN tags t ON nt.tag_id = t.id WHERE nt.note_id = ?')
    .bind(id)
    .all();
  tags = results.map((r: any) => r.name);
} catch (e) {
  console.error(e);
}

// 3. Fetch attachments
let attachments: any[] = [];
try {
  const { results } = await db
    .prepare('SELECT id, filename, file_size, mime_type, created_at FROM attachments WHERE note_id = ?')
    .bind(id)
    .all();
  attachments = results;
} catch (e) {
  console.error(e);
}

// 4. Fetch links
let links: any[] = [];
try {
  const { results } = await db
    .prepare('SELECT id, url, type, title, thumbnail_url, watch_progress FROM links WHERE note_id = ?')
    .bind(id)
    .all();
  links = results;
} catch (e) {
  console.error(e);
}

// 5. Fetch Backlinks
let incomingBacklinks: any[] = [];
try {
  const { results } = await db
    .prepare(
      `SELECT n.id, n.title 
       FROM backlinks b 
       JOIN notes n ON b.source_note_id = n.id 
       WHERE b.target_note_id = ? AND n.user_id = ?`
    )
    .bind(id, user.id)
    .all();
  incomingBacklinks = results;
} catch (e) {
  console.error(e);
}

// 6. Fetch Related notes
let relatedNotes: any[] = [];
try {
  if (note.category) {
    const { results } = await db
      .prepare('SELECT id, title, category, semester FROM notes WHERE category = ? AND id != ? AND user_id = ? LIMIT 3')
      .bind(note.category, id, user.id)
      .all();
    relatedNotes = results;
  }
} catch (e) {
  console.error(e);
}

// 7. Fetch user collections for moving folder
let collections: Collection[] = [];
try {
  const { results } = await db
    .prepare('SELECT * FROM collections WHERE user_id = ? ORDER BY name ASC')
    .bind(user.id)
    .all<Collection>();
  collections = results;
} catch (e) {
  console.error(e);
}

// Format bytes helper
const formatBytes = (bytes: number) => {
  if (bytes === 0) return '0 B';
  const k = 1024;
  const sizes = ['B', 'KB', 'MB', 'GB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
};

// Helper to extract Google Drive embed preview URL
function getDriveEmbedUrl(url: string): string | null {
  try {
    const driveUrl = new URL(url);
    if (driveUrl.hostname.includes('drive.google.com') || driveUrl.hostname.includes('docs.google.com')) {
      const fileMatch = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
      if (fileMatch) return `https://drive.google.com/file/d/${fileMatch[1]}/preview`;

      const docMatch = url.match(/\/document\/d\/([a-zA-Z0-9_-]+)/);
      if (docMatch) return `https://docs.google.com/document/d/${docMatch[1]}/preview`;

      const presMatch = url.match(/\/presentation\/d\/([a-zA-Z0-9_-]+)/);
      if (presMatch) return `https://docs.google.com/presentation/d/${presMatch[1]}/preview`;

      const sheetMatch = url.match(/\/spreadsheets\/d\/([a-zA-Z0-9_-]+)/);
      if (sheetMatch) return `https://docs.google.com/spreadsheets/d/${sheetMatch[1]}/preview`;

      const idParam = driveUrl.searchParams.get('id');
      if (idParam) return `https://drive.google.com/file/d/${idParam}/preview`;
    }
  } catch (e) {}
  return null;
}

const drivePreviews = links
  .filter((l) => l.type === 'drive')
  .map((l) => ({
    ...l,
    embedUrl: getDriveEmbedUrl(l.url),
  }));

const youtubeVideos = links.filter((l) => l.type === 'youtube');
const pdfs = attachments.filter((a) => a.mime_type === 'application/pdf');
const images = attachments.filter((a) => a.mime_type.startsWith('image/'));
const hasPreviews = pdfs.length > 0 || images.length > 0 || youtubeVideos.length > 0 || drivePreviews.some(d => !!d.embedUrl);
---

<Layout title={`${note.title} - PoraHobe`}>
  <!-- Reading progress bar for Focus Mode -->
  <div class="focus-progress-bar-container" id="focus-progress-container">
    <div class="focus-progress-bar" id="focus-progress"></div>
  </div>

  <div class="note-view-wrapper animate-fade-in" id="note-view-wrapper" data-note-id={note.id}>
    <!-- Action Toolbar -->
    <div class="note-toolbar bento-card">
      <div class="toolbar-left">
        <a href="/notes" class="toolbar-btn" title="Back to Notes">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" x2="5" y1="12" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span class="desktop-only">Back</span>
        </a>
        <div class="divider"></div>
        <span class="folder-indicator">
          <svg class="lucide lucide-folder" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: middle; color: var(--accent-primary);"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
          <select id="move-collection-select" title="Move folder">
            <option value="">Root / None</option>
            {collections.map((col) => (
              <option value={col.id} selected={col.id === note.collection_id}>{col.name}</option>
            ))}
          </select>
        </span>
      </div>

      <div class="toolbar-right">
        <!-- Bookmark -->
        <button class={`toolbar-btn ${note.is_favorite ? 'active' : ''}`} id="bookmark-toggle-btn" title="Bookmark">
          <span class="star-icon">
            <svg class="lucide lucide-star" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: middle;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </span>
          <span class="desktop-only">Favorite</span>
        </button>

        <!-- Pin -->
        <button class={`toolbar-btn ${note.is_pinned ? 'active' : ''}`} id="pin-toggle-btn" title="Pin note">
          <span>📌</span>
          <span class="desktop-only">Pin</span>
        </button>

        <div class="divider"></div>

        <!-- Focus Mode Toggle -->
        <button class="toolbar-btn" id="focus-mode-btn" title="Distraction-free Focus Mode">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"></path>
          </svg>
          <span>Focus</span>
        </button>

        <!-- Edit Toggle -->
        <button class="toolbar-btn" id="edit-mode-btn" title="Edit Note">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
          </svg>
          <span>Edit</span>
        </button>

        <button class="toolbar-btn danger" id="delete-note-btn" title="Delete Note">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 6h18M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Main Content Area -->
    <div class="note-main-layout" id="note-main-layout">
      <!-- READ PANEL -->
      <div class="read-pane bento-card" id="read-pane">
        <div class="note-meta-header">
          <h1 class="note-title-text" id="note-view-title">{note.title}</h1>
          <div class="note-metadata-tags">
            {note.category && <span class="badge badge-category">{formatCategoryName(note.category)}</span>}
            {note.semester && <span class="badge badge-semester">{note.semester}</span>}
            {note.topic && <span class="badge badge-topic">Topic: {note.topic}</span>}
          </div>
        </div>

        {hasPreviews && (
          <div class="preview-hub">
            <div class="preview-hub-tabs">
              {pdfs.map((pdf) => (
                <button class="preview-tab-btn" data-tab-type="pdf" data-target-id={`pdf-preview-${pdf.id}`}>
                  <svg class="lucide lucide-file-text" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                  {pdf.filename.length > 20 ? pdf.filename.slice(0, 17) + '...' : pdf.filename}
                </button>
              ))}
              {images.map((img) => (
                <button class="preview-tab-btn" data-tab-type="image" data-target-id={`image-preview-${img.id}`}>
                  <svg class="lucide lucide-image" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  {img.filename.length > 20 ? img.filename.slice(0, 17) + '...' : img.filename}
                </button>
              ))}
              {youtubeVideos.map((video) => (
                <button class="preview-tab-btn" data-tab-type="youtube" data-target-id={`yt-preview-${video.id}`}>
                  <svg class="lucide lucide-video" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.934a.5.5 0 0 0-.777-.416L16 11Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>
                  Video Preview
                </button>
              ))}
              {drivePreviews.filter(d => d.embedUrl).map((drive) => (
                <button class="preview-tab-btn" data-tab-type="drive" data-target-id={`drive-preview-${drive.id}`}>
                  <svg class="lucide lucide-folder" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
                  Drive Preview
                </button>
              ))}
            </div>

            <div class="preview-hub-panes">
              {pdfs.map((pdf) => (
                <div class="preview-pane-content hidden" id={`pdf-preview-${pdf.id}`}>
                  <div class="preview-header-bar">
                    <span class="file-name">
                      <svg class="lucide lucide-file-text" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle; color: var(--accent-primary);"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                      {pdf.filename} ({formatBytes(pdf.file_size)})
                    </span>
                    <a href={`/api/files/${pdf.id}`} download class="btn btn-secondary btn-sm" style="padding: 6px 12px; font-size: 0.8rem;">Download PDF</a>
                  </div>
                  <iframe src={`/api/files/${pdf.id}`} class="pdf-viewer-iframe" title={pdf.filename}></iframe>
                </div>
              ))}
              
              {images.map((img) => (
                <div class="preview-pane-content hidden" id={`image-preview-${img.id}`}>
                  <div class="preview-header-bar">
                    <span class="file-name">
                      <svg class="lucide lucide-image" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle; color: var(--accent-primary);"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                      {img.filename} ({formatBytes(img.file_size)})
                    </span>
                    <a href={`/api/files/${img.id}`} download class="btn btn-secondary btn-sm" style="padding: 6px 12px; font-size: 0.8rem;">Download Image</a>
                  </div>
                  <div class="image-preview-frame">
                    <img src={`/api/files/${img.id}`} alt={img.filename} class="preview-image-img" />
                  </div>
                </div>
              ))}

              {youtubeVideos.map((video) => {
                const videoId = video.thumbnail_url?.split('/vi/')[1]?.split('/')[0] || '';
                return (
                  <div class="preview-pane-content hidden" id={`yt-preview-${video.id}`}>
                    <div class="youtube-player-container-main" data-video-id={videoId} data-link-id={video.id} data-progress={video.watch_progress || 0}>
                      <div class="player-wrapper-main">
                        <div id={`yt-player-main-${video.id}`}></div>
                      </div>
                      <div class="player-meta-main">
                        <span class="player-title">
                          <svg class="lucide lucide-video" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle; color: var(--accent-primary);"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.934a.5.5 0 0 0-.777-.416L16 11Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>
                          {video.title || 'YouTube Resource'}
                        </span>
                        <span class="progress-info" id={`progress-text-main-${video.id}`}>
                          Saved progress: {Math.floor((video.watch_progress || 0) / 60)}m {(video.watch_progress || 0) % 60}s
                        </span>
                      </div>
                    </div>
                  </div>
                );
              })}

              {drivePreviews.filter(d => d.embedUrl).map((drive) => (
                <div class="preview-pane-content hidden" id={`drive-preview-${drive.id}`}>
                  <div class="preview-header-bar">
                    <span class="file-name">
                      <svg class="lucide lucide-folder" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle; color: var(--accent-primary);"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
                      {drive.title || 'Google Drive File'}
                    </span>
                    <a href={drive.url} target="_blank" class="btn btn-secondary btn-sm" style="padding: 6px 12px; font-size: 0.8rem;">Open Drive ↗</a>
                  </div>
                  <iframe src={drive.embedUrl!} class="pdf-viewer-iframe" title={drive.title || 'Google Drive Embed'}></iframe>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="prose note-body-rendered" id="note-body-rendered">
          <!-- Server side static loading fallback, client marked updates it -->
          <div class="loading-prose">Rendering notes content...</div>
        </div>

        <!-- Backlinks Section -->
        {incomingBacklinks.length > 0 && (
          <div class="backlinks-section">
            <h4>Linked references (Backlinks)</h4>
            <div class="backlinks-list">
              {incomingBacklinks.map((bl) => (
                <a href={`/notes/${bl.id}`} class="backlink-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                  </svg>
                  <span>{bl.title}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- EDIT PANEL (Only visible during edit-mode, splits screen) -->
      <div class="edit-pane bento-card hidden" id="edit-pane">
        <div class="edit-form">
          <input type="text" id="edit-title-input" value={note.title} class="edit-title-input" />
          
          <div class="edit-meta-grid">
            <div class="form-group">
              <label>Category</label>
              <input type="text" id="edit-category-input" value={note.category || ''} />
            </div>
            <div class="form-group">
              <label>Semester</label>
              <input type="text" id="edit-semester-input" value={note.semester || ''} />
            </div>
            <div class="form-group">
              <label>Topic</label>
              <input type="text" id="edit-topic-input" value={note.topic || ''} />
            </div>
            <div class="form-group">
              <label>Tags (comma separated)</label>
              <input type="text" id="edit-tags-input" value={tags.join(', ')} />
            </div>
          </div>

          <textarea id="edit-content-input" class="edit-content-textarea">{note.content}</textarea>
          
          <div class="edit-actions">
            <button class="btn btn-secondary" id="cancel-edit-btn">Cancel</button>
            <button class="btn btn-primary" id="save-edit-btn">Save Changes</button>
          </div>
        </div>
      </div>

      <!-- SIDEBAR WIDGETS (Only visible in normal/read mode, hidden in focus mode) -->
      <div class="side-widgets" id="side-widgets">
        <!-- Drag-and-drop file upload zone -->
        <div class="bento-card upload-zone" id="upload-zone">
          <div class="upload-prompt">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="upload-icon">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"></path>
            </svg>
            <p>Drag & Drop Files Here</p>
            <span>or click to browse</span>
            <input type="file" id="file-input-field" class="hidden-input" multiple />
          </div>

          <!-- Attachments list -->
          <div class="attachments-container">
            <h4>Attachments</h4>
            <ul class="attachments-list" id="attachments-list">
              {attachments.length === 0 ? (
                <li class="empty-attachment-text" id="empty-att-msg">No files attached yet</li>
              ) : (
                attachments.map((att) => (
                  <li class="attachment-item" data-att-id={att.id}>
                    <div class="att-info">
                      <a href={`/api/files/${att.id}`} target="_blank" class="att-name-link" title="Open file">
                        <svg class="lucide lucide-paperclip" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle; color: var(--text-muted);"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                        <span class="att-filename">{att.filename}</span>
                      </a>
                      <span class="att-size">{formatBytes(att.file_size)}</span>
                    </div>
                    <button class="delete-att-btn" data-att-id={att.id} title="Delete attachment">×</button>
                  </li>
                ))
              )}
            </ul>
          </div>
        </div>

        <!-- YouTube Video Embed Widget -->
        {links.some((l) => l.type === 'youtube') && (
          <div class="bento-card youtube-widget">
            <h3>YouTube Video Resources</h3>
            <div class="videos-list">
              {links.filter((l) => l.type === 'youtube').map((video) => {
                const videoId = video.thumbnail_url?.split('/vi/')[1]?.split('/')[0] || '';
                return (
                  <div class="youtube-player-container" data-video-id={videoId} data-link-id={video.id} data-progress={video.watch_progress}>
                    <div class="player-wrapper">
                      <div id={`yt-player-${video.id}`}></div>
                    </div>
                    <div class="player-meta">
                      <span class="player-title">{video.title || 'YouTube Resource'}</span>
                      <span class="progress-info" id={`progress-text-${video.id}`}>
                        Saved: {Math.floor(video.watch_progress / 60)}m {video.watch_progress % 60}s
                      </span>
                    </div>
                  </div>
                );
              })}
            </div>
            <!-- Clickable timestamps list explanation -->
            <div class="timestamp-help">
              <svg class="lucide lucide-lightbulb" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle; color: var(--warning);"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A7 7 0 0 0 6 8c0 1 .5 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
              **Tip:** Click any timestamp like `1:05` or `12:45` in the note content to jump directly to that part of the video!
            </div>
          </div>
        )}

        <!-- Google Drive Widget -->
        {links.some((l) => l.type === 'drive') && (
          <div class="bento-card drive-widget">
