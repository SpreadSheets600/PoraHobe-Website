---
import Layout from '../../layouts/Layout.astro';
import type { Collection } from '../../utils/db';
import { env } from 'cloudflare:workers';
import { formatCategoryName } from '../../utils/categories';
import BentoCard from '../../components/BentoCard.astro';
import Icon from '../../components/Icon.astro';

const user = Astro.locals.user;
const db = env.DB;
if (!user || !db) return Astro.redirect('/login');

const { id } = Astro.params;
if (!id) return Astro.redirect('/notes');

let note: any = null;
try {
  note = await db.prepare(`SELECT n.*, c.name as collection_name FROM notes n LEFT JOIN collections c ON n.collection_id = c.id WHERE n.id = ? AND n.user_id = ?`).bind(id, user.id).first();
} catch (e) { console.error('Error fetching note details:', e); }
if (!note) return Astro.redirect('/notes');
note.is_favorite = !!note.is_favorite;
note.is_pinned = !!note.is_pinned;

let tags: string[] = [];
let attachments: any[] = [];
let links: any[] = [];
let incomingBacklinks: any[] = [];
let relatedNotes: any[] = [];
let collections: Collection[] = [];

try {
  const { results: t } = await db.prepare('SELECT t.name FROM note_tags nt JOIN tags t ON nt.tag_id = t.id WHERE nt.note_id = ?').bind(id).all();
  tags = t.map((r: any) => r.name);
  const { results: a } = await db.prepare('SELECT id, filename, file_size, mime_type, created_at FROM attachments WHERE note_id = ?').bind(id).all();
  attachments = a;
  const { results: l } = await db.prepare('SELECT id, url, type, title, thumbnail_url, watch_progress FROM links WHERE note_id = ?').bind(id).all();
  links = l;
  const { results: b } = await db.prepare(`SELECT n.id, n.title FROM backlinks b JOIN notes n ON b.source_note_id = n.id WHERE b.target_note_id = ? AND n.user_id = ?`).bind(id, user.id).all();
  incomingBacklinks = b;
  if (note.category) {
    const { results: r } = await db.prepare('SELECT id, title, category, semester FROM notes WHERE category = ? AND id != ? AND user_id = ? LIMIT 3').bind(note.category, id, user.id).all();
    relatedNotes = r;
  }
  const { results: c } = await db.prepare('SELECT * FROM collections WHERE user_id = ? ORDER BY name ASC').bind(user.id).all<Collection>();
  collections = c;
} catch (e) { console.error(e); }

const formatBytes = (bytes: number) => {
  if (bytes === 0) return '0 B';
  const k = 1024, sizes = ['B', 'KB', 'MB', 'GB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
};

function getDriveEmbedUrl(url: string): string | null {
  try {
    const driveUrl = new URL(url);
    if (driveUrl.hostname.includes('drive.google.com') || driveUrl.hostname.includes('docs.google.com')) {
      const fileMatch = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
      if (fileMatch) return `https://drive.google.com/file/d/${fileMatch[1]}/preview`;
      const docMatch = url.match(/\/document\/d\/([a-zA-Z0-9_-]+)/);
      if (docMatch) return `https://docs.google.com/document/d/${docMatch[1]}/preview`;
      const presMatch = url.match(/\/presentation\/d\/([a-zA-Z0-9_-]+)/);
      if (presMatch) return `https://docs.google.com/presentation/d/${presMatch[1]}/preview`;
      const sheetMatch = url.match(/\/spreadsheets\/d\/([a-zA-Z0-9_-]+)/);
      if (sheetMatch) return `https://docs.google.com/spreadsheets/d/${sheetMatch[1]}/preview`;
      const idParam = driveUrl.searchParams.get('id');
      if (idParam) return `https://drive.google.com/file/d/${idParam}/preview`;
    }
  } catch {}
  return null;
}

const drivePreviews = links.filter((l) => l.type === 'drive').map((l) => ({ ...l, embedUrl: getDriveEmbedUrl(l.url) }));
const youtubeVideos = links.filter((l) => l.type === 'youtube');
const pdfs = attachments.filter((a) => a.mime_type === 'application/pdf');
const images = attachments.filter((a) => a.mime_type.startsWith('image/'));
const hasPreviews = pdfs.length > 0 || images.length > 0 || youtubeVideos.length > 0 || drivePreviews.some(d => !!d.embedUrl);
---

<Layout title={`${note.title} - PoraHobe`}>
  <div id="focus-progress-container" class="fixed top-0 left-0 w-screen h-1 bg-[var(--bg-tertiary)] z-1000 hidden">
    <div id="focus-progress" class="h-full w-0 bg-[var(--accent-primary)] transition-[width_var(--transition-fast)]"></div>
  </div>

  <div id="note-view-wrapper" data-note-id={note.id} class="max-w-[1200px] mx-auto flex flex-col gap-5 animate-[fadeIn_0.4s_cubic-bezier(0.16,1,0.3,1)_forwards]">
    <BentoCard class="flex justify-between items-center !py-3 !px-6" padding>
      <div class="flex items-center gap-2">
        <a href="/notes" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--text-primary)] no-underline">
          <Icon name="arrow-left" size={18} />
          <span class="max-sm:hidden">Back</span>
        </a>
        <span class="w-px h-6 bg-[var(--card-border)] mx-1"></span>
        <span class="flex items-center gap-1.5 bg-[var(--bg-secondary)] px-3 py-1.5 rounded-[var(--border-radius-md)] border border-[var(--card-border)] text-sm">
          <Icon name="folder" size={16} class="text-[var(--accent-primary)]" />
          <select id="move-collection-select" title="Move folder" class="text-sm font-semibold text-[var(--text-secondary)] cursor-pointer bg-transparent border-none outline-none">
            <option value="">Root / None</option>
            {collections.map((col) => (<option value={col.id} selected={col.id === note.collection_id}>{col.name}</option>))}
          </select>
        </span>
      </div>
      <div class="flex items-center gap-2">
        <button class={`toolbar-btn inline-flex items-center gap-2 px-3.5 py-2 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--text-primary)] ${note.is_favorite ? 'bg-[var(--accent-glow)] border-[var(--accent-primary)] text-[var(--accent-primary)]' : ''}`} id="bookmark-toggle-btn" title="Bookmark">
          <Icon name="star" size={16} class={note.is_favorite ? 'text-[var(--warning)]' : ''} />
          <span class="max-sm:hidden">Favorite</span>
        </button>
        <button class={`toolbar-btn inline-flex items-center gap-2 px-3.5 py-2 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--text-primary)] ${note.is_pinned ? 'bg-[var(--accent-glow)] border-[var(--accent-primary)] text-[var(--accent-primary)]' : ''}`} id="pin-toggle-btn" title="Pin note">
          <Icon name="pin" size={16} />
          <span class="max-sm:hidden">Pin</span>
        </button>
        <span class="w-px h-6 bg-[var(--card-border)] mx-1"></span>
        <button class="inline-flex items-center gap-2 px-3.5 py-2 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--text-primary)]" id="focus-mode-btn" title="Distraction-free Focus Mode">
          <Icon name="maximize" size={18} />
          <span>Focus</span>
        </button>
        <button class="inline-flex items-center gap-2 px-3.5 py-2 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)] hover:text-[var(--text-primary)]" id="edit-mode-btn" title="Edit Note">
          <Icon name="edit" size={18} />
          <span>Edit</span>
        </button>
        <button class="inline-flex items-center justify-center px-3.5 py-2 rounded-[var(--border-radius-md)] text-sm font-semibold cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] text-[var(--text-secondary)] hover:bg-[hsla(347,77%,50%,0.1)] hover:border-[var(--danger)] hover:text-[var(--danger)]" id="delete-note-btn" title="Delete Note">
          <Icon name="trash" size={18} />
        </button>
      </div>
    </BentoCard>

    <div id="note-main-layout" class="grid grid-cols-[8fr_4fr] gap-5 items-start max-lg:grid-cols-1" id="read-pane">
      <BentoCard class="flex flex-col gap-6 !p-8" padding>
        <div class="border-b border-[var(--card-border)] pb-4">
          <h1 id="note-view-title" class="text-[2rem] font-bold tracking-tight mb-3">{note.title}</h1>
          <div class="flex gap-2">
            {note.category && <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-[var(--border-radius-full)] border w-fit bg-[var(--accent-glow)] text-[var(--accent-primary)] border-[hsla(262,83%,58%,0.15)]">{formatCategoryName(note.category)}</span>}
            {note.semester && <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-[var(--border-radius-full)] border w-fit bg-[var(--bg-tertiary)] text-[var(--text-secondary)] border-[var(--card-border)]">{note.semester}</span>}
            {note.topic && <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-[var(--border-radius-full)] border w-fit bg-[var(--bg-secondary)] text-[var(--text-muted)] border-[var(--card-border)]">Topic: {note.topic}</span>}
          </div>
        </div>

        {hasPreviews && (
          <div class="flex flex-col overflow-hidden border border-[var(--card-border)] bg-[var(--card-bg)] rounded-[var(--border-radius-lg)] mb-6">
            <div class="flex flex-wrap bg-[var(--bg-secondary)] border-b border-[var(--card-border)] px-3 py-1.5 gap-[6.5px]">
              {pdfs.map((pdf) => (
                <button class="preview-tab-btn px-4 py-2 text-sm font-semibold text-[var(--text-secondary)] rounded-[var(--border-radius-md)] cursor-pointer transition-all duration-[var(--transition-fast)] border border-transparent inline-flex items-center gap-1.5 hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]" data-tab-type="pdf" data-target-id={`pdf-preview-${pdf.id}`}>
                  <Icon name="file-text" size={14} />{pdf.filename.length > 20 ? pdf.filename.slice(0, 17) + '...' : pdf.filename}
                </button>
              ))}
              {images.map((img) => (
                <button class="preview-tab-btn px-4 py-2 text-sm font-semibold text-[var(--text-secondary)] rounded-[var(--border-radius-md)] cursor-pointer transition-all duration-[var(--transition-fast)] border border-transparent inline-flex items-center gap-1.5 hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]" data-tab-type="image" data-target-id={`image-preview-${img.id}`}>
                  <Icon name="image" size={14} />{img.filename.length > 20 ? img.filename.slice(0, 17) + '...' : img.filename}
                </button>
              ))}
              {youtubeVideos.map((video) => (
                <button class="preview-tab-btn px-4 py-2 text-sm font-semibold text-[var(--text-secondary)] rounded-[var(--border-radius-md)] cursor-pointer transition-all duration-[var(--transition-fast)] border border-transparent inline-flex items-center gap-1.5 hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]" data-tab-type="youtube" data-target-id={`yt-preview-${video.id}`}>
                  <Icon name="video" size={14} />Video Preview
                </button>
              ))}
              {drivePreviews.filter(d => d.embedUrl).map((drive) => (
                <button class="preview-tab-btn px-4 py-2 text-sm font-semibold text-[var(--text-secondary)] rounded-[var(--border-radius-md)] cursor-pointer transition-all duration-[var(--transition-fast)] border border-transparent inline-flex items-center gap-1.5 hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]" data-tab-type="drive" data-target-id={`drive-preview-${drive.id}`}>
                  <Icon name="folder" size={14} />Drive Preview
                </button>
              ))}
            </div>

            <div class="preview-panes">
              {pdfs.map((pdf) => (
                <div class="preview-pane-content flex-col w-full" id={`pdf-preview-${pdf.id}`} style="display:none">
                  <div class="flex justify-between items-center px-6 py-3 bg-[var(--bg-primary)] border-b border-[var(--card-border)]">
                    <span class="font-semibold text-sm text-[var(--text-primary)] truncate max-w-[70%]">
                      <Icon name="file-text" size={16} class="mr-1.5 text-[var(--accent-primary)]" />{pdf.filename} ({formatBytes(pdf.file_size)})
                    </span>
                    <a href={`/api/files/${pdf.id}`} download class="inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-[var(--border-radius-md)] font-semibold text-xs cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--text-muted)] hover:text-[var(--text-primary)]">Download PDF</a>
                  </div>
                  <iframe src={`/api/files/${pdf.id}`} class="w-full h-[680px] border-none bg-[var(--bg-secondary)]" title={pdf.filename}></iframe>
                </div>
              ))}
              {images.map((img) => (
                <div class="preview-pane-content flex-col w-full" id={`image-preview-${img.id}`} style="display:none">
                  <div class="flex justify-between items-center px-6 py-3 bg-[var(--bg-primary)] border-b border-[var(--card-border)]">
                    <span class="font-semibold text-sm text-[var(--text-primary)] truncate max-w-[70%]">
                      <Icon name="image" size={16} class="mr-1.5 text-[var(--accent-primary)]" />{img.filename} ({formatBytes(img.file_size)})
                    </span>
                    <a href={`/api/files/${img.id}`} download class="inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-[var(--border-radius-md)] font-semibold text-xs cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--text-muted)] hover:text-[var(--text-primary)]">Download Image</a>
                  </div>
                  <div class="w-full flex justify-center items-center bg-[#0f0f11] p-8 min-h-[350px]">
                    <img src={`/api/files/${img.id}`} alt={img.filename} class="max-w-full max-h-[600px] rounded-[var(--border-radius-md)] shadow-[0_8px_30px_rgba(0,0,0,0.5)] object-contain" />
                  </div>
                </div>
              ))}
              {youtubeVideos.map((video) => {
                const videoId = video.thumbnail_url?.split('/vi/')[1]?.split('/')[0] || '';
                return (
                  <div class="preview-pane-content flex-col w-full" id={`yt-preview-${video.id}`} style="display:none">
                    <div class="youtube-player-container-main w-full bg-black" data-video-id={videoId} data-link-id={video.id} data-progress={video.watch_progress || 0}>
                      <div class="relative aspect-video w-full bg-black">
                        <div id={`yt-player-main-${video.id}`} class="absolute inset-0 w-full h-full border-none"></div>
                      </div>
                      <div class="flex justify-between items-center px-6 py-4 bg-[var(--bg-primary)] border-t border-[var(--card-border)]">
                        <span class="player-title font-semibold text-sm text-[var(--text-primary)]"><Icon name="video" size={16} class="mr-1.5 text-[var(--accent-primary)]" />{video.title || 'YouTube Resource'}</span>
                        <span class="progress-info text-xs text-[var(--text-muted)] font-medium" id={`progress-text-main-${video.id}`}>Saved progress: {Math.floor((video.watch_progress || 0) / 60)}m {(video.watch_progress || 0) % 60}s</span>
                      </div>
                    </div>
                  </div>
                );
              })}
              {drivePreviews.filter(d => d.embedUrl).map((drive) => (
                <div class="preview-pane-content flex-col w-full" id={`drive-preview-${drive.id}`} style="display:none">
                  <div class="flex justify-between items-center px-6 py-3 bg-[var(--bg-primary)] border-b border-[var(--card-border)]">
                    <span class="font-semibold text-sm text-[var(--text-primary)] truncate max-w-[70%]"><Icon name="folder" size={16} class="mr-1.5 text-[var(--accent-primary)]" />{drive.title || 'Google Drive File'}</span>
                    <a href={drive.url} target="_blank" class="inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-[var(--border-radius-md)] font-semibold text-xs cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--text-muted)] hover:text-[var(--text-primary)]">Open Drive ↗</a>
                  </div>
                  <iframe src={drive.embedUrl!} class="w-full h-[680px] border-none bg-[var(--bg-secondary)]" title={drive.title || 'Google Drive Embed'}></iframe>
                </div>
              ))}
            </div>
          </div>
        )}

        <div id="note-body-rendered" class="min-h-[200px] prose max-w-none [&_img]:max-w-full [&_img]:rounded-[var(--border-radius-md)] [&_img]:my-6 [&_img]:border [&_img]:border-[var(--card-border)]">
          <div class="text-[var(--text-muted)] italic">Rendering notes content...</div>
        </div>

        {incomingBacklinks.length > 0 && (
          <div class="border-t border-[var(--card-border)] pt-6 mt-6">
            <h4 class="text-sm text-[var(--text-muted)] mb-3 font-semibold uppercase tracking-wider">Linked references (Backlinks)</h4>
            <div class="flex flex-wrap gap-2.5">
              {incomingBacklinks.map((bl) => (
                <a href={`/notes/${bl.id}`} class="inline-flex items-center gap-2 bg-[var(--bg-secondary)] border border-[var(--card-border)] px-3 py-1.5 rounded-[var(--border-radius-md)] text-sm text-[var(--text-secondary)] font-medium no-underline hover:border-[var(--accent-primary)] hover:text-[var(--text-primary)]">
                  <Icon name="link" size={14} />
                  <span>{bl.title}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </BentoCard>

      <div id="side-widgets" class="flex flex-col gap-5">
        <BentoCard class="flex flex-col gap-5 !p-5 cursor-pointer transition-all duration-[var(--transition-fast)]" id="upload-zone" padding>
          <div class="border-2 border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] py-6 px-4 text-center flex flex-col items-center gap-1.5 relative">
            <Icon name="upload" size={24} class="text-[var(--text-muted)] mb-1" />
            <p class="text-sm font-semibold">Drag & Drop Files Here</p>
            <span class="text-xs text-[var(--text-muted)]">or click to browse</span>
            <input type="file" id="file-input-field" class="absolute inset-0 opacity-0 cursor-pointer" multiple />
          </div>
          <div class="flex flex-col gap-2">
            <h4 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-2">Attachments</h4>
            <ul id="attachments-list" class="flex flex-col gap-1.5 list-none">
              {attachments.length === 0 ? (
                <li id="empty-att-msg" class="text-sm text-[var(--text-muted)] italic">No files attached yet</li>
              ) : (
                attachments.map((att) => (
                  <li class="attachment-item flex justify-between items-center bg-[var(--bg-secondary)] border border-[var(--card-border)] px-3 py-2 rounded-[var(--border-radius-md)] text-sm" data-att-id={att.id}>
                    <div class="flex flex-col min-w-0">
                      <a href={`/api/files/${att.id}`} target="_blank" class="att-name-link font-medium text-[var(--text-secondary)] truncate hover:text-[var(--accent-primary)] no-underline">
                        <Icon name="paperclip" size={14} class="mr-1.5 text-[var(--text-muted)]" />
                        <span class="att-filename">{att.filename}</span>
                      </a>
                      <span class="text-[0.7rem] text-[var(--text-muted)]">{formatBytes(att.file_size)}</span>
                    </div>
                    <button class="delete-att-btn text-lg text-[var(--text-muted)] cursor-pointer px-1 rounded hover:text-[var(--danger)] hover:bg-[var(--bg-tertiary)]" data-att-id={att.id} title="Delete attachment">×</button>
                  </li>
                ))
              )}
            </ul>
          </div>
        </BentoCard>

        {links.some((l) => l.type === 'youtube') && (
          <BentoCard class="flex flex-col gap-4">
            <h3 class="text-sm font-semibold text-[var(--text-primary)]">YouTube Video Resources</h3>
            <div class="videos-list flex flex-col gap-5">
              {links.filter((l) => l.type === 'youtube').map((video) => {
                const videoId = video.thumbnail_url?.split('/vi/')[1]?.split('/')[0] || '';
                return (
                  <div class="youtube-player-container flex flex-col gap-2" data-video-id={videoId} data-link-id={video.id} data-progress={video.watch_progress}>
                    <div class="relative aspect-video rounded-[var(--border-radius-md)] overflow-hidden bg-black border border-[var(--card-border)]">
                      <div id={`yt-player-${video.id}`} class="absolute inset-0 w-full h-full border-none"></div>
                    </div>
                    <div class="flex justify-between items-center gap-2.5">
                      <span class="player-title text-sm font-semibold text-[var(--text-primary)] truncate">{video.title || 'YouTube Resource'}</span>
                      <span class="progress-info text-xs text-[var(--text-muted)] whitespace-nowrap" id={`progress-text-${video.id}`}>Saved: {Math.floor(video.watch_progress / 60)}m {video.watch_progress % 60}s</span>
                    </div>
                  </div>
                );
              })}
            </div>
            <div class="text-xs text-[var(--text-muted)] leading-relaxed pt-2.5 border-t border-[var(--card-border)]">
              <Icon name="zap" size={14} class="mr-1.5 text-[var(--warning)]" />
              <strong>Tip:</strong> Click any timestamp like <code>1:05</code> or <code>12:45</code> in the note content to jump directly to that part of the video!
            </div>
          </BentoCard>
        )}

        {links.some((l) => l.type === 'drive') && (
          <BentoCard class="flex flex-col gap-4">
            <h3 class="text-sm font-semibold text-[var(--text-primary)]">Connected Drive Files</h3>
            <div class="flex flex-col gap-2 mt-2">
              {links.filter((l) => l.type === 'drive').map((link) => (
                <a href={link.url} target="_blank" class="flex items-center gap-3 px-3.5 py-2.5 bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] transition-colors duration-[var(--transition-fast)] hover:border-[var(--accent-primary)] no-underline">
                  <span class="text-[var(--accent-secondary)] flex items-center justify-center">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10v6M12 2v20M2 10h20M2 16h20M12 2L2 10M12 2l10 8M12 22L2 16M12 22l10-6"></path></svg>
                  </span>
                  <div class="flex flex-col min-w-0">
                    <span class="text-sm font-semibold text-[var(--text-primary)] truncate">{link.title || 'Google Drive File'}</span>
                    <span class="text-[0.7rem] text-[var(--text-muted)]">View on Google Drive ↗</span>
                  </div>
                </a>
              ))}
            </div>
          </BentoCard>
        )}

        {relatedNotes.length > 0 && (
          <BentoCard class="flex flex-col gap-4">
            <h3 class="text-sm font-semibold text-[var(--text-primary)]">Related Materials</h3>
            <div class="flex flex-col gap-2 mt-2">
              {relatedNotes.map((rn) => (
                <a href={`/notes/${rn.id}`} class="flex flex-col gap-1 px-3.5 py-2.5 bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] transition-colors duration-[var(--transition-fast)] hover:border-[var(--accent-primary)] no-underline">
                  <span class="text-sm font-semibold text-[var(--text-primary)]">{rn.title}</span>
                  <span class="text-xs text-[var(--text-muted)]">{rn.category} • {rn.semester}</span>
                </a>
              ))}
            </div>
          </BentoCard>
        )}
      </div>
    </div>

    <div id="edit-pane" class="flex-col gap-5" style="display:none">
      <BentoCard class="flex flex-col gap-5 !p-8">
        <input type="text" id="edit-title-input" value={note.title} class="text-[1.75rem] font-bold border-b border-[var(--card-border)] pb-2 w-full text-[var(--text-primary)] bg-transparent outline-none" />
        <div class="grid grid-cols-4 max-md:grid-cols-2 gap-3">
          {[
            { id: 'edit-category-input', value: note.category || '', label: 'Category' },
            { id: 'edit-semester-input', value: note.semester || '', label: 'Semester' },
            { id: 'edit-topic-input', value: note.topic || '', label: 'Topic' },
            { id: 'edit-tags-input', value: tags.join(', '), label: 'Tags (comma separated)' },
          ].map((f) => (
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">{f.label}</label>
              <input type="text" id={f.id} value={f.value} class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3 py-2 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" />
            </div>
          ))}
        </div>
        <textarea id="edit-content-input" class="h-[400px] resize-vertical font-mono text-sm leading-relaxed bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] p-4 text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">{note.content}</textarea>
        <div class="flex justify-end gap-3">
          <button id="cancel-edit-btn" class="inline-flex items-center justify-center gap-2 px-[18px] py-2.5 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--text-muted)] hover:text-[var(--text-primary)]">Cancel</button>
          <button id="save-edit-btn" class="inline-flex items-center justify-center gap-2 px-[18px] py-2.5 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)]">Save Changes</button>
        </div>
      </BentoCard>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js" is:inline></script>

  <style is:global>
    body.focus-active #sidebar { display: none !important; }
    body.focus-active header { display: none !important; }
    body.focus-active #side-widgets { display: none !important; }
    body.focus-active main { padding: 0 !important; background: var(--bg-primary); display: flex; justify-content: center; overflow-y: auto; }
    body.focus-active #note-main-layout { grid-template-columns: 1fr; width: 720px; max-width: 90%; margin: 48px auto; }
    body.focus-active #note-body-rendered { background: none !important; }
    #note-view-wrapper.editing #note-main-layout { grid-template-columns: 1fr 1fr; }
    @media (max-width: 1024px) { #note-view-wrapper.editing #note-main-layout { grid-template-columns: 1fr; } }
    #note-view-wrapper.editing #side-widgets { display: none; }
    .preview-tab-btn.active { background: var(--card-bg); color: var(--accent-primary); border-color: var(--card-border); box-shadow: var(--shadow-sm); }
    .math-display { margin: 1.5em 0; overflow-x: auto; padding: 10px; background: var(--bg-secondary); border-radius: var(--border-radius-md); text-align: center; }
    .math-inline { padding: 0 4px; }
  </style>

  <script>
    const noteViewWrapper = document.getElementById('note-view-wrapper');
    const noteId = noteViewWrapper?.dataset.noteId;
    const editPane = document.getElementById('edit-pane');
    const editModeBtn = document.getElementById('edit-mode-btn');
    const cancelEditBtn = document.getElementById('cancel-edit-btn');
    const saveEditBtn = document.getElementById('save-edit-btn');
    const editTitleInput = document.getElementById('edit-title-input');
    const editContentInput = document.getElementById('edit-content-input');
    const editCategoryInput = document.getElementById('edit-category-input');
    const editSemesterInput = document.getElementById('edit-semester-input');
    const editTopicInput = document.getElementById('edit-topic-input');
    const editTagsInput = document.getElementById('edit-tags-input');
    const viewTitleText = document.getElementById('note-view-title');
    const viewBodyRendered = document.getElementById('note-body-rendered');

    const renderContent = (markdownText) => {
      if (!viewBodyRendered) return;
      let html = typeof marked !== 'undefined' ? marked.parse(markdownText) : markdownText;
      html = html.replace(/\$\$([\s\S]*?)\$\$/g, (match, equation) => {
        try { return `<div class="math-display">${katex.renderToString(equation, { displayMode: true, throwOnError: false })}</div>`; } catch { return match; }
      });
      html = html.replace(/\$([^$\n]+?)\$/g, (match, equation) => {
        try { return `<span class="math-inline">${katex.renderToString(equation, { displayMode: false, throwOnError: false })}</span>`; } catch { return match; }
      });
      html = html.replace(/\b(\d{1,2}:)?(\d{1,2}):(\d{2})\b/g, (match) => {
        const parts = match.split(':').map(Number);
        let seconds = parts.length === 3 ? parts[0] * 3600 + parts[1] * 60 + parts[2] : parts[0] * 60 + parts[1];
        return `<a href="#" class="youtube-timestamp" data-seconds="${seconds}">${match}</a>`;
      });
      viewBodyRendered.innerHTML = html;
      viewBodyRendered.querySelectorAll('.youtube-timestamp').forEach((link) => {
        link.addEventListener('click', (e) => { e.preventDefault(); seekActiveVideos(Number(link.dataset.seconds)); });
      });
    };

    const previewTabs = document.querySelectorAll('.preview-tab-btn');
    const previewPanes = document.querySelectorAll('.preview-pane-content');
    if (previewTabs.length > 0) {
      previewTabs[0].classList.add('active');
      const firstTargetId = previewTabs[0].dataset.targetId;
      if (firstTargetId) {
        const firstPane = document.getElementById(firstTargetId);
        if (firstPane) firstPane.style.display = 'flex';
      }
      previewTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          previewTabs.forEach((t) => t.classList.remove('active'));
          previewPanes.forEach((p) => { (p as HTMLElement).style.display = 'none'; });
          tab.classList.add('active');
          const targetId = tab.dataset.targetId;
          if (targetId) {
            const pane = document.getElementById(targetId);
            if (pane) pane.style.display = 'flex';
          }
        });
      });
    }

    if (editContentInput) renderContent(editContentInput.value);

    editModeBtn?.addEventListener('click', () => {
      const isEditing = noteViewWrapper.classList.toggle('editing');
      if (editPane) editPane.style.display = isEditing ? 'flex' : 'none';
      if (isEditing) { editModeBtn.classList.add('active'); editContentInput?.focus(); }
      else editModeBtn.classList.remove('active');
    });

    cancelEditBtn?.addEventListener('click', () => {
      noteViewWrapper.classList.remove('editing');
      if (editPane) editPane.style.display = 'none';
      editModeBtn?.classList.remove('active');
      if (editTitleInput) editTitleInput.value = viewTitleText?.textContent || '';
    });

    saveEditBtn?.addEventListener('click', async () => {
      const title = editTitleInput.value.trim();
      const content = editContentInput.value;
      const category = editCategoryInput.value.trim();
      const semester = editSemesterInput.value.trim();
      const topic = editTopicInput.value.trim();
      const tags = editTagsInput.value.split(',').map((t) => t.trim()).filter((t) => t.length > 0);
      if (!title) { alert('Title is required'); return; }
      try {
        saveEditBtn.setAttribute('disabled', 'true'); saveEditBtn.textContent = 'Saving...';
        const res = await fetch(`/api/notes/${noteId}`, {
          method: 'PUT', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, content, category, semester, topic, tags }),
        });
        if (res.ok) window.location.reload();
        else { const data = await res.json(); alert(data.error || 'Failed to update note'); }
      } catch { alert('Failed to save changes'); }
      finally { saveEditBtn.removeAttribute('disabled'); saveEditBtn.textContent = 'Save Changes'; }
    });

    const focusModeBtn = document.getElementById('focus-mode-btn');
    const focusProgressContainer = document.getElementById('focus-progress-container');
    const focusProgressBar = document.getElementById('focus-progress');
    focusModeBtn?.addEventListener('click', () => {
      const isFocus = document.body.classList.toggle('focus-active');
      focusModeBtn.classList.toggle('active');
      if (isFocus) { focusProgressContainer.style.display = 'block'; window.addEventListener('scroll', trackingFocusScroll); trackingFocusScroll(); }
      else { focusProgressContainer.style.display = 'none'; window.removeEventListener('scroll', trackingFocusScroll); }
    });
    const trackingFocusScroll = () => {
      if (!focusProgressBar) return;
      const winScroll = document.documentElement.scrollTop || document.body.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      focusProgressBar.style.width = height > 0 ? (winScroll / height) * 100 + '%' : '0';
    };

    const bookmarkBtn = document.getElementById('bookmark-toggle-btn');
    bookmarkBtn?.addEventListener('click', async () => {
      const isFavorite = bookmarkBtn.classList.toggle('active');
      try { await fetch(`/api/notes/${noteId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ is_favorite: isFavorite }) }); } catch {}
    });

    const pinBtn = document.getElementById('pin-toggle-btn');
    pinBtn?.addEventListener('click', async () => {
      const isPinned = pinBtn.classList.toggle('active');
      try { await fetch(`/api/notes/${noteId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ is_pinned: isPinned }) }); } catch {}
    });

    const moveColSelect = document.getElementById('move-collection-select');
    moveColSelect?.addEventListener('change', async () => {
      const colId = moveColSelect.value || null;
      try { await fetch(`/api/notes/${noteId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ collection_id: colId }) }); window.location.reload(); } catch {}
    });

    const deleteNoteBtn = document.getElementById('delete-note-btn');
    deleteNoteBtn?.addEventListener('click', async () => {
      if (confirm('Are you sure you want to delete this note and ALL its attached files?')) {
        try {
          const res = await fetch(`/api/notes/${noteId}`, { method: 'DELETE' });
          if (res.ok) window.location.href = '/notes';
          else { const data = await res.json(); alert(data.error || 'Failed to delete note'); }
        } catch { alert('An error occurred'); }
      }
    });

    // YouTube IFrame API - loads after the page is ready
    let playerPromises = {};
    let tag = document.createElement('script');
    tag.src = 'https://www.youtube.com/iframe_api';
    let firstScriptTag = document.getElementsByTagName('script')[0];
    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

    window.onYouTubeIframeAPIReady = () => {
      document.querySelectorAll('.youtube-player-container, .youtube-player-container-main').forEach((container) => {
        const videoId = container.dataset.videoId;
        const linkId = container.dataset.linkId;
        const savedProgress = Number(container.dataset.progress || 0);
        if (!videoId) return;

        const playerDiv = container.querySelector('[id^="yt-player-"], [id^="yt-player-main-"]');
        if (!playerDiv) return;

        const isMain = playerDiv.id.includes('main');
        const player = new YT.Player(playerDiv.id, {
          videoId,
          playerVars: { start: savedProgress, rel: 0, modestbranding: 1 },
          events: {
            onReady: () => {
              if (savedProgress > 0) player.seekTo(savedProgress, true);
            },
            onStateChange: (event) => {
              const progressTextId = isMain ? `progress-text-main-${linkId}` : `progress-text-${linkId}`;
              const progressEl = document.getElementById(progressTextId);
              if (event.data === YT.PlayerState.PLAYING) {
                const interval = setInterval(() => {
                  const currentTime = Math.floor(player.getCurrentTime());
                  const mins = Math.floor(currentTime / 60);
                  const secs = currentTime % 60;
                  if (progressEl) progressEl.textContent = `${mins}m ${secs}s`;
                  navigator.sendBeacon('/api/progress', new URLSearchParams({ linkId, progress: String(currentTime) }));
                }, 5000);
                playerDiv.dataset.intervalId = interval;
              } else {
                clearInterval(Number(playerDiv.dataset.intervalId));
              }
            },
          },
        });
        playerPromises[playerDiv.id] = player;
      });
    };

    window.seekActiveVideos = (seconds) => {
      Object.values(playerPromises).forEach((player) => {
        if (player && player.seekTo) player.seekTo(seconds, true);
      });
    };

    // Upload zone drag-and-drop
    const uploadZone = document.getElementById('upload-zone');
    const fileInput = document.getElementById('file-input-field');
    const attachmentsList = document.getElementById('attachments-list');
    const emptyAttMsg = document.getElementById('empty-att-msg');

    uploadZone?.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
    uploadZone?.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
    uploadZone?.addEventListener('drop', (e) => { e.preventDefault(); uploadZone.classList.remove('dragover'); if (e.dataTransfer.files.length > 0) uploadFiles(e.dataTransfer.files); });
    fileInput?.addEventListener('change', () => { if (fileInput.files.length > 0) uploadFiles(fileInput.files); });

    const uploadFiles = async (files) => {
      for (const file of Array.from(files)) {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('noteId', noteId);
        try {
          const res = await fetch('/api/upload', { method: 'POST', body: formData });
          if (res.ok) window.location.reload();
          else { const data = await res.json(); alert('Upload failed: ' + data.error); }
        } catch { alert('Upload failed due to connection error'); }
      }
    };

    // Delete individual attachment
    document.querySelectorAll('.delete-att-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const attId = btn.dataset.attId;
        if (!attId) return;
        if (confirm('Delete this attachment from storage?')) {
          try {
            const res = await fetch(`/api/files/${attId}`, { method: 'DELETE' });
            if (res.ok) window.location.reload();
            else alert('Failed to delete attachment');
          } catch { alert('An error occurred'); }
        }
      });
    });
  </script>
</Layout>
