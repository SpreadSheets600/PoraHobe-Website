---
import Layout from '../../layouts/Layout.astro';
import type { LinkItem } from '../../utils/db';
import { env } from 'cloudflare:workers';
import BentoCard from '../../components/BentoCard.astro';
import Icon from '../../components/Icon.astro';

const user = Astro.locals.user;
const db = env.DB;

if (!user || !db) return Astro.redirect('/login');

let watchProgressVideos: (LinkItem & { note_title: string })[] = [];
try {
  const { results } = await db
    .prepare(`SELECT l.*, n.title as note_title FROM links l JOIN notes n ON l.note_id = n.id WHERE n.user_id = ? AND l.type = 'youtube' AND l.watch_progress > 0 ORDER BY l.created_at DESC`)
    .bind(user.id)
    .all<LinkItem & { note_title: string }>();
  watchProgressVideos = results;
} catch (e) { console.error('Failed to load video history:', e); }
---

<Layout title="Watch History - PoraHobe">
  <div class="max-w-[1200px] mx-auto flex flex-col gap-6 animate-[fadeIn_0.4s_cubic-bezier(0.16,1,0.3,1)_forwards]">
    <div class="flex justify-between items-end gap-5 max-sm:flex-col max-sm:items-stretch">
      <div>
        <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--text-muted)] no-underline mb-2 transition-colors duration-[var(--transition-fast)] hover:text-[var(--accent-primary)]">
          <Icon name="arrow-left" size={16} />
          Back to Dashboard
        </a>
        <h2 class="flex items-center gap-2.5 text-[1.75rem] font-bold text-[var(--text-primary)] m-0">
          <Icon name="clock" size={24} class="text-[var(--accent-primary)]" />
          Watch History
        </h2>
        <p class="mt-1 text-sm text-[var(--text-muted)]">{watchProgressVideos.length} video{watchProgressVideos.length === 1 ? '' : 's'} with watch progress</p>
      </div>
      {watchProgressVideos.length > 0 && (
        <button id="clear-all-btn" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-[var(--border-radius-md)] font-medium text-sm cursor-pointer border transition-all duration-[var(--transition-fast)] bg-transparent border-[var(--danger)] text-[var(--danger)] hover:bg-[var(--danger)] hover:text-white hover:shadow-[0_0_12px_rgba(239,68,68,0.2)]">
          <Icon name="trash" size={16} />
          Clear All History
        </button>
      )}
    </div>

    {watchProgressVideos.length > 0 && (
      <BentoCard class="!p-4">
        <div class="relative flex items-center">
          <Icon name="search" size={18} class="absolute left-3.5 text-[var(--text-muted)] pointer-events-none" />
          <input type="text" id="history-search" placeholder="Search videos by title or note..." class="w-full py-3 pl-[42px] pr-4 bg-[var(--bg-primary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] text-sm text-[var(--text-primary)] outline-none transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:shadow-[0_0_0_2px_rgba(139,92,246,0.15)]" />
        </div>
      </BentoCard>
    )}

    {watchProgressVideos.length === 0 ? (
      <BentoCard class="flex flex-col items-center justify-center gap-4 py-16 text-center">
        <Icon name="video" size={48} class="text-[var(--text-muted)] opacity-60" />
        <h3 class="text-lg font-semibold text-[var(--text-primary)]">No watch history found</h3>
        <p class="text-sm text-[var(--text-muted)] max-w-[400px]">Start watching embedded YouTube videos inside your study notes to track progress automatically.</p>
        <a href="/notes" class="inline-flex items-center justify-center gap-2 px-[18px] py-2.5 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] hover:-translate-y-px mt-3">Browse Study Materials</a>
      </BentoCard>
    ) : (
      <div id="history-grid" class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-5">
        {watchProgressVideos.map((video) => {
          const mins = Math.floor(video.watch_progress / 60);
          const secs = video.watch_progress % 60;
          return (
            <div class="history-card flex flex-col overflow-hidden border border-[var(--card-border)] rounded-[var(--border-radius-lg)] bg-[var(--card-bg)] backdrop-blur-[16px] shadow-[var(--shadow-sm)] transition-all duration-[var(--transition-normal)] hover:-translate-y-1 hover:shadow-[var(--shadow-md)] hover:border-[var(--accent-primary)]" data-title={video.title?.toLowerCase() || ''} data-note={video.note_title?.toLowerCase() || ''}>
              <div class="relative aspect-video w-full bg-[var(--bg-tertiary)] overflow-hidden">
                {video.thumbnail_url ? (
                  <img src={video.thumbnail_url} alt={video.title || 'YouTube Video'} loading="lazy" class="w-full h-full object-cover transition-transform duration-[var(--transition-normal)] group-hover:scale-105" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-[var(--text-muted)] bg-gradient-to-br from-[var(--bg-secondary)] to-[var(--bg-tertiary)]">
                    <Icon name="video" size={32} />
                  </div>
                )}
                <div class="absolute bottom-2 right-2 bg-black/75 backdrop-blur-[4px] text-white text-xs font-semibold px-2 py-1 rounded-[var(--border-radius-sm)] z-2">{mins}m {secs}s watched</div>
                <a href={`/notes/${video.note_id}`} class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 transition-opacity duration-[var(--transition-fast)] z-1 hover:opacity-100" title="Resume Watching">
                  <div class="w-12 h-12 rounded-full bg-[var(--accent-primary)] text-white flex items-center justify-center scale-90 transition-all duration-[var(--transition-fast)] hover:scale-100 hover:bg-[var(--accent-hover)]">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="ml-0.5"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
                  </div>
                </a>
              </div>
              <div class="p-4 flex flex-col gap-3 flex-1">
                <a href={`/notes/${video.note_id}`} class="no-underline text-[var(--text-primary)]">
                  <h4 class="m-0 text-sm font-semibold leading-relaxed line-clamp-2 transition-colors duration-[var(--transition-fast)] hover:text-[var(--accent-primary)]">{video.title || 'YouTube Video'}</h4>
                </a>
                <div class="flex items-center gap-1.5 text-xs text-[var(--text-muted)]">
                  <Icon name="file" size={14} class="shrink-0" />
                  <span>Note: {video.note_title}</span>
                </div>
                <div class="flex justify-between items-center gap-2 mt-auto pt-1">
                  <a href={`/notes/${video.note_id}`} class="flex-1 inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-[var(--border-radius-md)] font-medium text-xs cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)]">Resume</a>
                  <button class="delete-single-btn flex-1 inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-[var(--border-radius-md)] font-medium text-xs cursor-pointer border transition-all duration-[var(--transition-fast)] bg-transparent border-[var(--danger)] text-[var(--danger)] hover:bg-[var(--danger)] hover:text-white" data-link-id={video.id} title="Remove from history">
                    <Icon name="trash" size={14} />
                    Remove
                  </button>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>

  <script>
    const searchInput = document.getElementById('history-search') as HTMLInputElement;
    const cards = document.querySelectorAll('.history-card');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const q = searchInput.value.toLowerCase().trim();
        cards.forEach((card) => {
          const title = card.getAttribute('data-title') || '';
          const note = card.getAttribute('data-note') || '';
          (card as HTMLElement).style.display = (title.includes(q) || note.includes(q)) ? '' : 'none';
        });
      });
    }

    const clearAllBtn = document.getElementById('clear-all-btn');
    if (clearAllBtn) {
      clearAllBtn.addEventListener('click', async () => {
        if (confirm('Are you sure you want to clear all your watch progress history?')) {
          try {
            const res = await fetch('/api/progress', { method: 'DELETE' });
            if (res.ok) window.location.reload();
            else alert('Failed to clear history');
          } catch { alert('An error occurred'); }
        }
      });
    }

    document.querySelectorAll('.delete-single-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault(); e.stopPropagation();
        const linkId = btn.getAttribute('data-link-id');
        if (!linkId) return;
        if (confirm('Remove this video from your watch history?')) {
          try {
            const res = await fetch('/api/progress', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ linkId, progress: 0 }),
            });
            if (res.ok) window.location.reload();
            else alert('Failed to remove item');
          } catch { alert('An error occurred'); }
        }
      });
    });
  </script>
</Layout>
