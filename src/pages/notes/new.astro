---
import Layout from '../../layouts/Layout.astro';
import type { Collection } from '../../utils/db';
import { env } from 'cloudflare:workers';
import { toKebabCase, formatCategoryName } from '../../utils/categories';
import BentoCard from '../../components/BentoCard.astro';
import Icon from '../../components/Icon.astro';

const user = Astro.locals.user;
const db = env.DB;

if (!user || !db) return Astro.redirect('/login');

let collections: Collection[] = [];
let existingCategories: string[] = [];
try {
  const { results } = await db.prepare('SELECT * FROM collections WHERE user_id = ? ORDER BY name ASC').bind(user.id).all<Collection>();
  collections = results;
  const catRes = await db.prepare('SELECT DISTINCT category FROM notes WHERE user_id = ? AND category IS NOT NULL AND category != ""').bind(user.id).all();
  existingCategories = catRes.results.map((r: any) => r.category);
} catch (e) { console.error('Failed to load collections/categories:', e); }
---

<Layout title="Share Material - PoraHobe">
  <div class="max-w-[1100px] mx-auto flex flex-col gap-6 animate-[fadeIn_0.4s_cubic-bezier(0.16,1,0.3,1)_forwards]">
    <div class="flex justify-between items-center border-b border-[var(--card-border)] pb-4 mb-2">
      <div class="flex flex-col gap-1.5">
        <a href="/notes" class="inline-flex items-center gap-1.5 text-sm text-[var(--text-muted)] font-medium no-underline transition-colors duration-[var(--transition-fast)] hover:text-[var(--accent-primary)]">
          <Icon name="arrow-left" size={16} />
          <span>Back to Materials</span>
        </a>
        <h2 class="text-[1.6rem] font-bold tracking-tight text-[var(--text-primary)] m-0">Share Study Material</h2>
      </div>
      <button class="btn-primary inline-flex items-center justify-center gap-2 px-[18px] py-2.5 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] hover:-translate-y-px" id="save-material-btn">
        <Icon name="heart" size={16} />
        <span>Share Resource</span>
      </button>
    </div>

    <div class="grid grid-cols-12 gap-6">
      <BentoCard class="col-span-8 max-lg:col-span-12 flex flex-col gap-6" padding>
        <div class="flex flex-col gap-1.5">
          <label for="material-title" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Resource Title</label>
          <input type="text" id="material-title" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-[18px] py-3.5 text-base font-semibold text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" placeholder="e.g. Lecture 1 Notes, Calculus Cheat Sheet..." required />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="material-url" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Resource URL (Optional)</label>
          <input type="url" id="material-url" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" placeholder="Paste YouTube, Google Drive, or Web link here..." />
          <span class="text-xs text-[var(--text-muted)] mt-1">Enter a URL to generate preview embeds automatically. Leave empty for plain notes.</span>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="material-description" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Description / Brief Notes (Optional)</label>
          <textarea id="material-description" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)] resize-vertical min-h-[200px]" placeholder="Add any details, context, key topics covered, or timestamps for videos..." rows="8"></textarea>
        </div>
      </BentoCard>

      <BentoCard class="col-span-4 max-lg:col-span-12 flex flex-col gap-5" padding>
        <h3 class="text-lg font-bold text-[var(--text-primary)] border-b border-[var(--card-border)] pb-2.5 m-0">Material Metadata</h3>
        <div class="flex flex-col gap-5">
          <div class="flex flex-col gap-1.5">
            <label for="material-collection" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Target Folder</label>
            <select id="material-collection" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
              <option value="">Root / None</option>
              {collections.map((col) => (<option value={col.id}>{col.name}</option>))}
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-category-select" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Category / Subject</label>
            <select id="material-category-select" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
              <option value="general">General</option>
              {existingCategories.filter(cat => cat && toKebabCase(cat) !== 'general').map((cat) => (<option value={toKebabCase(cat)}>{formatCategoryName(cat)}</option>))}
              <option value="__new__">+ Add New Category...</option>
            </select>
          </div>
          <div id="new-category-input-group" class="flex-col gap-1.5 hidden" style="margin-top: -12px;">
            <label for="new-category-input" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">New Category Name</label>
            <input type="text" id="new-category-input" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" placeholder="e.g. Computer Architecture" />
            <span class="text-xs text-[var(--text-muted)] mt-1">Saved as: <code id="new-category-preview" class="text-[var(--accent-primary)] text-xs">general</code></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-semester-select" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Semester</label>
            <select id="material-semester-select" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
              {['All', 'Semester 1', 'Semester 2', 'Semester 3', 'Semester 4', 'Semester 5', 'Semester 6', 'Semester 7', 'Semester 8'].map((s) => (<option value={s}>{s}</option>))}
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-topic" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Topic</label>
            <input type="text" id="material-topic" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" placeholder="e.g. Data Structures" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-tags" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Tags (comma separated)</label>
            <input type="text" id="material-tags" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" placeholder="e.g. revision, cheat-sheet, midsem" />
          </div>
          <div class="w-full h-px bg-[var(--card-border)] my-1"></div>
          <div class="flex flex-col gap-3.5">
            {[
              { id: 'material-favorite', label: 'Bookmark (Favorite)' },
              { id: 'material-pinned', label: 'Pin to Dashboard' },
            ].map((t) => (
              <label class="relative inline-flex items-center gap-3 cursor-pointer select-none">
                <input type="checkbox" id={t.id} class="peer opacity-0 w-0 h-0 absolute" />
                <span class="relative w-[38px] h-5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] transition-all duration-[var(--transition-normal)] rounded-full shrink-0 before:content-[''] before:absolute before:h-3 before:w-3 before:left-[3px] before:bottom-[3px] before:bg-[var(--text-muted)] before:transition-all before:duration-[var(--transition-normal)] before:rounded-full peer-checked:bg-[var(--accent-primary)] peer-checked:border-[var(--accent-primary)] peer-checked:before:translate-x-[18px] peer-checked:before:bg-white"></span>
                <span class="text-sm font-medium text-[var(--text-secondary)]">{t.label}</span>
              </label>
            ))}
          </div>
        </div>
      </BentoCard>
    </div>
  </div>

  <script>
    const generatedNoteId = crypto.randomUUID();

    const categorySelect = document.getElementById('material-category-select');
    const newCategoryGroup = document.getElementById('new-category-input-group');
    const newCategoryInput = document.getElementById('new-category-input');
    const newCategoryPreview = document.getElementById('new-category-preview');

    categorySelect?.addEventListener('change', () => {
      if (categorySelect.value === '__new__') {
        if (newCategoryGroup) newCategoryGroup.style.display = 'flex';
        newCategoryInput?.focus();
      } else {
        if (newCategoryGroup) newCategoryGroup.style.display = 'none';
      }
    });

    newCategoryInput?.addEventListener('input', () => {
      const slug = newCategoryInput.value.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      if (newCategoryPreview) newCategoryPreview.textContent = slug || 'your-category';
    });

    const getFinalCategory = () => {
      if (categorySelect.value === '__new__') {
        const raw = newCategoryInput.value.trim();
        if (!raw) return 'general';
        const slug = raw.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
        const existingMatch = Array.from(categorySelect.options).find((opt) => opt.value !== '__new__' && opt.value === slug);
        return existingMatch ? existingMatch.value : slug;
      }
      return categorySelect.value || 'general';
    };

    const saveMaterialBtn = document.getElementById('save-material-btn');
    saveMaterialBtn?.addEventListener('click', async (e) => {
      e.preventDefault();
      const title = document.getElementById('material-title').value.trim();
      const url = document.getElementById('material-url').value.trim();
      const description = document.getElementById('material-description').value;
      const collectionId = document.getElementById('material-collection').value || null;
      const category = getFinalCategory();
      const semester = document.getElementById('material-semester-select').value || 'All';
      const topic = document.getElementById('material-topic').value.trim();
      const tagsString = document.getElementById('material-tags').value;
      const isFavorite = document.getElementById('material-favorite').checked;
      const isPinned = document.getElementById('material-pinned').checked;

      if (!title) { alert('Resource Title is required.'); return; }

      const tags = tagsString.split(',').map((t) => t.trim()).filter((t) => t.length > 0);
      let noteBody = description || '';
      if (url) noteBody = `${url}\n\n${noteBody}`;

      try {
        saveMaterialBtn.setAttribute('disabled', 'true');
        saveMaterialBtn.innerHTML = '<span>Saving...</span>';
        const res = await fetch('/api/notes', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: generatedNoteId, title, content: noteBody, collection_id: collectionId, category: category || 'general', semester: semester || 'All', topic: topic || 'General', is_favorite: isFavorite, is_pinned: isPinned, tags }),
        });
        const data = await res.json();
        if (res.ok) {
          window.location.href = `/notes/${generatedNoteId}`;
        } else { alert(data.error || 'Failed to share material'); saveMaterialBtn.removeAttribute('disabled'); saveMaterialBtn.innerHTML = '<span>Share Resource</span>'; }
      } catch (err) { console.error(err); alert('An error occurred during submission.'); saveMaterialBtn.removeAttribute('disabled'); saveMaterialBtn.innerHTML = '<span>Share Resource</span>'; }
    });
  </script>
</Layout>
