---
import Layout from '../../layouts/Layout.astro';
import type { Collection } from '../../utils/db';
import { env } from 'cloudflare:workers';
import { toKebabCase, formatCategoryName } from '../../utils/categories';
import BentoCard from '../../components/BentoCard.astro';
import Icon from '../../components/Icon.astro';

const user = Astro.locals.user;
const db = env.DB;

if (!user || !db) return Astro.redirect('/login');

let collections: Collection[] = [];
let existingCategories: string[] = [];
try {
  const { results } = await db.prepare('SELECT * FROM collections WHERE user_id = ? ORDER BY name ASC').bind(user.id).all<Collection>();
  collections = results;
  const catRes = await db.prepare('SELECT DISTINCT category FROM notes WHERE user_id = ? AND category IS NOT NULL AND category != ""').bind(user.id).all();
  existingCategories = catRes.results.map((r: any) => r.category);
} catch (e) { console.error('Failed to load collections/categories:', e); }
---

<Layout title="Share Material - PoraHobe">
  <div class="max-w-[1100px] mx-auto flex flex-col gap-6 animate-[fadeIn_0.4s_cubic-bezier(0.16,1,0.3,1)_forwards]">
    <div class="flex justify-between items-center border-b border-[var(--card-border)] pb-4 mb-2">
      <div class="flex flex-col gap-1.5">
        <a href="/notes" class="inline-flex items-center gap-1.5 text-sm text-[var(--text-muted)] font-medium no-underline transition-colors duration-[var(--transition-fast)] hover:text-[var(--accent-primary)]">
          <Icon name="arrow-left" size={16} />
          <span>Back to Materials</span>
        </a>
        <h2 class="text-[1.6rem] font-bold tracking-tight text-[var(--text-primary)] m-0">Share Study Material</h2>
      </div>
      <button class="btn-primary inline-flex items-center justify-center gap-2 px-[18px] py-2.5 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] hover:-translate-y-px" id="save-material-btn">
        <Icon name="heart" size={16} />
        <span>Share Resource</span>
      </button>
    </div>

    <div class="grid grid-cols-12 gap-6">
      <BentoCard class="col-span-8 max-lg:col-span-12 flex flex-col gap-6" padding>
        <div class="flex flex-col gap-1.5">
          <label for="material-title" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Resource Title</label>
          <input type="text" id="material-title" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-[18px] py-3.5 text-base font-semibold text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" placeholder="e.g. Lecture 1 Notes, Calculus Cheat Sheet..." required />
        </div>

        <div class="flex flex-col gap-2.5">
          <label class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Select Resource Type</label>
          <div class="flex bg-[var(--bg-secondary)] border border-[var(--card-border)] p-1 rounded-[var(--border-radius-md)] gap-1">
            <button class="type-tab flex-1 py-2.5 text-sm font-semibold rounded-[var(--border-radius-sm)] cursor-pointer text-[var(--text-secondary)] transition-all duration-[var(--transition-fast)] text-center tab-active" id="tab-file-btn">
              <Icon name="folder" size={14} class="mr-1.5" />
              Upload File (PDF / Image)
            </button>
            <button class="type-tab flex-1 py-2.5 text-sm font-semibold rounded-[var(--border-radius-sm)] cursor-pointer text-[var(--text-secondary)] transition-all duration-[var(--transition-fast)] text-center" id="tab-link-btn">
              <Icon name="link" size={14} class="mr-1.5" />
              Share URL Link (YouTube / Drive)
            </button>
          </div>
        </div>

        <div id="file-upload-container" class="w-full min-h-[160px] flex flex-col gap-4">
          <div id="upload-dropzone" class="border-2 border-dashed border-[var(--card-border)] rounded-[var(--border-radius-md)] py-[42px] px-5 text-center flex flex-col items-center justify-center gap-2.5 bg-[var(--bg-secondary)] transition-all duration-[var(--transition-fast)] relative cursor-pointer hover:border-[var(--accent-primary)] hover:bg-[var(--accent-glow)] hover:shadow-[0_0_16px_rgba(139,92,246,0.05)]">
            <Icon name="upload" size={32} class="text-[var(--text-muted)] transition-colors duration-[var(--transition-fast)] group-hover:text-[var(--accent-primary)]" />
            <p class="font-semibold text-sm text-[var(--text-secondary)] m-0">Drag &amp; Drop your study file here</p>
            <span class="text-xs text-[var(--text-muted)]">Supports PDF, PNG, JPG (Max 50MB)</span>
            <button type="button" id="browse-files-btn" class="inline-flex items-center justify-center gap-2 px-3 py-1.5 rounded-[var(--border-radius-md)] font-medium text-xs cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--text-muted)] hover:text-[var(--text-primary)] mt-1">Browse Files</button>
            <input type="file" id="file-uploader-input" class="hidden" accept=".pdf,image/*" />
          </div>

          <div id="upload-progress-card" class="items-center gap-4 p-4 bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] relative" style="display:none">
            <span class="shrink-0 text-[var(--accent-primary)] flex items-center"><Icon name="paperclip" size={22} /></span>
            <div class="flex-1 flex flex-col gap-1.5 min-w-0">
              <div class="flex justify-between items-center gap-2">
                <span id="uploaded-filename" class="font-semibold text-sm text-[var(--text-primary)] truncate">file.pdf</span>
                <span id="upload-status-percent" class="text-xs font-bold text-[var(--accent-primary)] whitespace-nowrap">0%</span>
              </div>
              <span id="uploaded-filesize" class="text-xs text-[var(--text-muted)]">–</span>
              <div class="w-full h-1 bg-[var(--bg-tertiary)] rounded-[var(--border-radius-full)] overflow-hidden">
                <div id="upload-progress-fill" class="h-full w-0 bg-[var(--accent-primary)] transition-[width_0.15s_ease]"></div>
              </div>
            </div>
            <button id="remove-uploaded-file-btn" class="text-2xl text-[var(--text-muted)] cursor-pointer p-0 pr-2 bg-none border-none hover:text-[var(--danger)]" title="Remove">×</button>
          </div>
        </div>

        <div id="url-share-container" class="w-full min-h-[160px] flex-col gap-4" style="display:none">
          <div class="flex flex-col gap-1.5">
            <label for="material-url" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Resource URL</label>
            <input type="url" id="material-url" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" placeholder="Paste YouTube, Google Drive, or Web link here..." />
            <span class="text-xs text-[var(--text-muted)] mt-1">Enter URL to generate custom preview embeds automatically.</span>
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="material-description" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Description / Brief Notes (Optional)</label>
          <textarea id="material-description" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)] resize-vertical min-h-[200px]" placeholder="Add any details, context, key topics covered, or timestamps for videos..." rows="8"></textarea>
        </div>
      </BentoCard>

      <BentoCard class="col-span-4 max-lg:col-span-12 flex flex-col gap-5" padding>
        <h3 class="text-lg font-bold text-[var(--text-primary)] border-b border-[var(--card-border)] pb-2.5 m-0">Material Metadata</h3>
        <div class="flex flex-col gap-5">
          <div class="flex flex-col gap-1.5">
            <label for="material-collection" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Target Folder</label>
            <select id="material-collection" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
              <option value="">Root / None</option>
              {collections.map((col) => (<option value={col.id}>{col.name}</option>))}
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-category-select" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Category / Subject</label>
            <select id="material-category-select" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
              <option value="general">General</option>
              {existingCategories.filter(cat => cat && toKebabCase(cat) !== 'general').map((cat) => (<option value={toKebabCase(cat)}>{formatCategoryName(cat)}</option>))}
              <option value="__new__">+ Add New Category...</option>
            </select>
          </div>
          <div id="new-category-input-group" class="flex-col gap-1.5 hidden" style="margin-top: -12px;">
            <label for="new-category-input" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">New Category Name</label>
            <input type="text" id="new-category-input" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" placeholder="e.g. Computer Architecture" />
            <span class="text-xs text-[var(--text-muted)] mt-1">Saved as: <code id="new-category-preview" class="text-[var(--accent-primary)] text-xs">general</code></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-semester-select" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Semester</label>
            <select id="material-semester-select" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]">
              {['All', 'Semester 1', 'Semester 2', 'Semester 3', 'Semester 4', 'Semester 5', 'Semester 6', 'Semester 7', 'Semester 8'].map((s) => (<option value={s}>{s}</option>))}
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-topic" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Topic</label>
            <input type="text" id="material-topic" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" placeholder="e.g. Data Structures" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="material-tags" class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">Tags (comma separated)</label>
            <input type="text" id="material-tags" class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)]" placeholder="e.g. revision, cheat-sheet, midsem" />
          </div>
          <div class="w-full h-px bg-[var(--card-border)] my-1"></div>
          <div class="flex flex-col gap-3.5">
            {[
              { id: 'material-favorite', label: 'Bookmark (Favorite)' },
              { id: 'material-pinned', label: 'Pin to Dashboard' },
            ].map((t) => (
              <label class="relative inline-flex items-center gap-3 cursor-pointer select-none">
                <input type="checkbox" id={t.id} class="peer opacity-0 w-0 h-0 absolute" />
                <span class="relative w-[38px] h-5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] transition-all duration-[var(--transition-normal)] rounded-full shrink-0 before:content-[''] before:absolute before:h-3 before:w-3 before:left-[3px] before:bottom-[3px] before:bg-[var(--text-muted)] before:transition-all before:duration-[var(--transition-normal)] before:rounded-full peer-checked:bg-[var(--accent-primary)] peer-checked:border-[var(--accent-primary)] peer-checked:before:translate-x-[18px] peer-checked:before:bg-white"></span>
                <span class="text-sm font-medium text-[var(--text-secondary)]">{t.label}</span>
              </label>
            ))}
          </div>
        </div>
      </BentoCard>
    </div>
  </div>

  <style>
    .tab-active {
      background: var(--card-bg);
      color: var(--text-primary);
      box-shadow: var(--shadow-sm);
    }
  </style>

  <script>
    function toKebabCase(str) { return str.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); }

    let resourceType = 'file';
    let uploadedFileId = null;
    let uploadedFilenameText = '';
    let uploadedFileMime = '';
    let pendingFile = null;
    const generatedNoteId = crypto.randomUUID();

    const tabFileBtn = document.getElementById('tab-file-btn');
    const tabLinkBtn = document.getElementById('tab-link-btn');
    const fileUploadContainer = document.getElementById('file-upload-container');
    const urlShareContainer = document.getElementById('url-share-container');

    tabFileBtn?.addEventListener('click', (e) => {
      e.preventDefault(); resourceType = 'file';
      tabFileBtn.classList.add('tab-active');
      tabLinkBtn?.classList.remove('tab-active');
      if (fileUploadContainer) fileUploadContainer.style.display = 'flex';
      if (urlShareContainer) urlShareContainer.style.display = 'none';
    });

    tabLinkBtn?.addEventListener('click', (e) => {
      e.preventDefault(); resourceType = 'link';
      tabLinkBtn.classList.add('tab-active');
      tabFileBtn?.classList.remove('tab-active');
      if (urlShareContainer) urlShareContainer.style.display = 'flex';
      if (fileUploadContainer) fileUploadContainer.style.display = 'none';
    });

    const categorySelect = document.getElementById('material-category-select');
    const newCategoryGroup = document.getElementById('new-category-input-group');
    const newCategoryInput = document.getElementById('new-category-input');
    const newCategoryPreview = document.getElementById('new-category-preview');

    categorySelect?.addEventListener('change', () => {
      if (categorySelect.value === '__new__') {
        if (newCategoryGroup) newCategoryGroup.style.display = 'flex';
        newCategoryInput?.focus();
      } else {
        if (newCategoryGroup) newCategoryGroup.style.display = 'none';
      }
    });

    newCategoryInput?.addEventListener('input', () => {
      const slug = toKebabCase(newCategoryInput.value);
      if (newCategoryPreview) newCategoryPreview.textContent = slug || 'your-category';
    });

    const getFinalCategory = () => {
      if (categorySelect.value === '__new__') {
        const raw = newCategoryInput.value.trim();
        if (!raw) return 'general';
        const slug = toKebabCase(raw);
        const existingMatch = Array.from(categorySelect.options).find((opt) => opt.value !== '__new__' && opt.value === slug);
        return existingMatch ? existingMatch.value : slug;
      }
      return categorySelect.value || 'general';
    };

    const uploadDropzone = document.getElementById('upload-dropzone');
    const browseFilesBtn = document.getElementById('browse-files-btn');
    const fileUploaderInput = document.getElementById('file-uploader-input');
    const uploadProgressCard = document.getElementById('upload-progress-card');
    const uploadedFilenameEl = document.getElementById('uploaded-filename');
    const uploadedFilesizeEl = document.getElementById('uploaded-filesize');
    const uploadProgressFill = document.getElementById('upload-progress-fill');
    const uploadStatusPercent = document.getElementById('upload-status-percent');
    const removeUploadedFileBtn = document.getElementById('remove-uploaded-file-btn');
    const materialTitle = document.getElementById('material-title');

    browseFilesBtn?.addEventListener('click', () => fileUploaderInput.click());
    uploadDropzone?.addEventListener('click', (e) => { if (e.target !== browseFilesBtn) fileUploaderInput.click(); });
    uploadDropzone?.addEventListener('dragover', (e) => { e.preventDefault(); uploadDropzone.classList.add('dragover'); });
    uploadDropzone?.addEventListener('dragleave', () => uploadDropzone.classList.remove('dragover'));
    uploadDropzone?.addEventListener('drop', (e) => { e.preventDefault(); uploadDropzone.classList.remove('dragover'); if (e.dataTransfer?.files?.[0]) handleFileUpload(e.dataTransfer.files[0]); });
    fileUploaderInput?.addEventListener('change', () => { if (fileUploaderInput.files?.[0]) handleFileUpload(fileUploaderInput.files[0]); });

    const setProgress = (percent, done = false) => {
      if (uploadProgressFill) uploadProgressFill.style.width = `${percent}%`;
      if (uploadStatusPercent) {
        uploadStatusPercent.textContent = done ? '✓ Done' : `${percent}%`;
        uploadStatusPercent.style.color = done ? '#10b981' : '';
        if (done) uploadProgressFill.style.backgroundColor = '#10b981';
        else uploadProgressFill.style.backgroundColor = '';
      }
    };

    const formatBytes = (bytes) => {
      if (bytes === 0) return '0 B';
      const k = 1024, sizes = ['B', 'KB', 'MB', 'GB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    };

    const handleFileUpload = async (file) => {
      if (!file) return;
      if (!materialTitle.value.trim()) {
        const cleanName = file.name.substring(0, file.name.lastIndexOf('.')) || file.name;
        materialTitle.value = cleanName.replace(/[-_]/g, ' ');
      }
      pendingFile = file;
      uploadDropzone.classList.add('hidden');
      if (uploadProgressCard) uploadProgressCard.style.display = 'flex';
      uploadedFilenameEl.textContent = file.name;
      uploadedFilesizeEl.textContent = formatBytes(file.size);
      setProgress(0, false);
      if (uploadStatusPercent) uploadStatusPercent.textContent = 'Ready to upload after saving';
    };

    const resetUploadZone = () => {
      uploadedFileId = null; uploadedFilenameText = ''; uploadedFileMime = ''; pendingFile = null;
      if (uploadProgressFill) { uploadProgressFill.style.width = '0'; uploadProgressFill.style.backgroundColor = ''; }
      if (uploadStatusPercent) uploadStatusPercent.style.color = '';
      if (uploadProgressCard) uploadProgressCard.style.display = 'none';
      uploadDropzone?.classList.remove('hidden');
      fileUploaderInput.value = '';
    };

    removeUploadedFileBtn?.addEventListener('click', async (e) => {
      e.stopPropagation();
      if (uploadedFileId) {
        try { const res = await fetch(`/api/files/${uploadedFileId}`, { method: 'DELETE' }); if (res.ok) resetUploadZone(); else alert('Failed to remove uploaded file'); }
        catch (err) { console.error(err); }
      } else resetUploadZone();
    });

    const saveMaterialBtn = document.getElementById('save-material-btn');
    saveMaterialBtn?.addEventListener('click', async (e) => {
      e.preventDefault();
      const title = materialTitle.value.trim();
      const description = document.getElementById('material-description').value;
      const collectionId = document.getElementById('material-collection').value || null;
      const category = getFinalCategory();
      const semester = document.getElementById('material-semester-select').value || 'All';
      const topic = document.getElementById('material-topic').value.trim();
      const tagsString = document.getElementById('material-tags').value;
      const isFavorite = document.getElementById('material-favorite').checked;
      const isPinned = document.getElementById('material-pinned').checked;

      if (!title) { alert('Resource Title is required.'); return; }
      if (resourceType === 'file' && !pendingFile) { alert('Please upload a file first.'); return; }

      let shareUrl = '';
      if (resourceType === 'link') {
        shareUrl = document.getElementById('material-url').value.trim();
        if (!shareUrl) { alert('Please enter the URL link.'); return; }
      }

      const tags = tagsString.split(',').map((t) => t.trim()).filter((t) => t.length > 0);
      let noteBody = description || '';
      if (resourceType === 'link') noteBody = `${shareUrl}\n\n${noteBody}`;

      try {
        saveMaterialBtn.setAttribute('disabled', 'true');
        saveMaterialBtn.innerHTML = '<span>Saving...</span>';
        const res = await fetch('/api/notes', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: generatedNoteId, title, content: noteBody, collection_id: collectionId, category: category || 'general', semester: semester || 'All', topic: topic || 'General', is_favorite: isFavorite, is_pinned: isPinned, tags }),
        });
        const data = await res.json();
        if (res.ok) {
          if (pendingFile) {
            saveMaterialBtn.innerHTML = '<span>Uploading file...</span>';
            const formData = new FormData();
            formData.append('file', pendingFile);
            formData.append('noteId', generatedNoteId);
            try {
              const uploadRes = await fetch('/api/upload', { method: 'POST', body: formData });
              if (!uploadRes.ok) { const errData = await uploadRes.json(); console.error('File upload failed:', errData.error); }
            } catch (upErr) { console.error('File upload error:', upErr); }
          }
          window.location.href = `/notes/${generatedNoteId}`;
        } else { alert(data.error || 'Failed to share material'); saveMaterialBtn.removeAttribute('disabled'); saveMaterialBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Share Resource</span>'; }
      } catch (err) { console.error(err); alert('An error occurred during submission.'); saveMaterialBtn.removeAttribute('disabled'); saveMaterialBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg><span>Share Resource</span>'; }
    });
  </script>
</Layout>
