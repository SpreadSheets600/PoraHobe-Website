---
import Layout from '../../layouts/Layout.astro';
import type { Collection } from '../../utils/db';
import { env } from 'cloudflare:workers';

const user = Astro.locals.user;
const db = env.DB;

if (!user || !db) {
  return Astro.redirect('/login');
}

// Fetch user collections for dropdown
let collections: Collection[] = [];
try {
  const { results } = await db
    .prepare('SELECT * FROM collections WHERE user_id = ? ORDER BY name ASC')
    .bind(user.id)
    .all<Collection>();
  collections = results;
} catch (e) {
  console.error('Failed to load collections in creator:', e);
}

// Fetch pre-existing categories & semesters to provide autocomplete lists
let existingCategories: string[] = [];
let existingSemesters: string[] = [];
try {
  const catRes = await db
    .prepare('SELECT DISTINCT category FROM notes WHERE user_id = ? AND category IS NOT NULL AND category != ""')
    .bind(user.id)
    .all();
  existingCategories = catRes.results.map((r: any) => r.category);

  const semRes = await db
    .prepare('SELECT DISTINCT semester FROM notes WHERE user_id = ? AND semester IS NOT NULL AND semester != ""')
    .bind(user.id)
    .all();
  existingSemesters = semRes.results.map((r: any) => r.semester);
} catch (e) {
  console.error(e);
}
---

<Layout title="Share Material - PoraHobe">
  <div class="creator-wrapper animate-fade-in">
    <div class="creator-header">
      <div class="header-left">
        <a href="/notes" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" x2="5" y1="12" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>Back to Materials</span>
        </a>
        <h2>Share Study Material</h2>
      </div>
      <div class="header-right">
        <button class="btn btn-primary" id="save-material-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>Share Resource</span>
        </button>
      </div>
    </div>

    <!-- Main sharing form layout -->
    <div class="sharing-form-grid">
      <!-- Left side: primary content details -->
      <div class="bento-card col-span-8 main-form-pane">
        <div class="form-group">
          <label for="material-title">Resource Title</label>
          <input type="text" id="material-title" class="form-input title-field-input" placeholder="e.g. Lecture 1 Notes, Calculus Cheat Sheet..." required />
        </div>

        <!-- Share type selectors -->
        <div class="share-type-section">
          <label class="section-label">Select Resource Type</label>
            <button class="type-tab active" id="tab-file-btn">
              <svg class="lucide lucide-folder" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
              Upload File (PDF / Image)
            </button>
            <button class="type-tab" id="tab-link-btn">
              <svg class="lucide lucide-link" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px; display: inline-block; vertical-align: middle;"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              Share URL Link (YouTube / Drive)
            </button>
          </div>
        </div>

        <!-- File upload container -->
        <div class="type-container" id="file-upload-container">
          <div class="upload-dropzone" id="upload-dropzone">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="upload-icon">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"></path>
            </svg>
            <p class="upload-title">Drag & Drop your study file here</p>
            <span class="upload-subtext">Supports PDF, PNG, JPG (Max 50MB)</span>
            <button type="button" class="btn btn-secondary btn-sm" id="browse-files-btn">Browse Files</button>
            <input type="file" id="file-uploader-input" class="hidden-file-input" />
          </div>

          <!-- File Upload Progress / Complete States -->
          <div class="upload-progress-card hidden" id="upload-progress-card">
            <div class="file-icon">📎</div>
            <div class="file-details">
              <span class="file-name-label" id="uploaded-filename">lecture-notes.pdf</span>
              <span class="file-size-label" id="uploaded-filesize">2.4 MB</span>
              <!-- progress animation -->
              <div class="progress-bar-track">
                <div class="progress-bar-fill" id="upload-progress-fill"></div>
              </div>
            </div>
            <button class="remove-file-btn" id="remove-uploaded-file-btn" title="Remove attachment">×</button>
          </div>
        </div>

        <!-- URL sharing container -->
        <div class="type-container hidden" id="url-share-container">
          <div class="form-group">
            <label for="material-url">Resource URL</label>
            <input type="url" id="material-url" class="form-input" placeholder="Paste YouTube, Google Drive, or Web link here..." />
            <span class="helper-text">Enter URL to generate custom preview embeds automatically.</span>
          </div>
        </div>

        <div class="form-group description-group">
          <label for="material-description">Description / Brief Notes (Optional)</label>
          <textarea id="material-description" class="form-textarea" placeholder="Add any details, context, key topics covered, or timestamps for videos..." rows="8"></textarea>
        </div>
      </div>

      <!-- Right side: Metadata configurations -->
      <div class="bento-card col-span-4 meta-form-pane">
        <h3>Material Metadata</h3>
        <div class="meta-inputs-list">
          <!-- Folder select -->
          <div class="form-group">
            <label for="material-collection">Target Folder</label>
            <select id="material-collection" class="form-select">
              <option value="">Root / None</option>
              {collections.map((col) => (
                <option value={col.id}>{col.name}</option>
              ))}
            </select>
          </div>

          <!-- Category -->
          <div class="form-group">
            <label for="material-category">Category / Subject</label>
            <input type="text" id="material-category" class="form-input" placeholder="e.g. Computer Science" list="categories-list" required />
            <datalist id="categories-list">
              {existingCategories.map((cat) => <option value={cat} />)}
            </datalist>
          </div>

          <!-- Semester -->
          <div class="form-group">
            <label for="material-semester">Semester</label>
            <input type="text" id="material-semester" class="form-input" placeholder="e.g. Semester 3" list="semesters-list" />
            <datalist id="semesters-list">
              {existingSemesters.map((sem) => <option value={sem} />)}
            </datalist>
          </div>

          <!-- Topic -->
          <div class="form-group">
            <label for="material-topic">Topic</label>
            <input type="text" id="material-topic" class="form-input" placeholder="e.g. Data Structures" />
          </div>

          <!-- Tags -->
          <div class="form-group">
            <label for="material-tags">Tags (comma separated)</label>
            <input type="text" id="material-tags" class="form-input" placeholder="e.g. revision, cheat-sheet, midsem" />
          </div>

          <div class="divider"></div>

          <!-- Toggles -->
          <div class="toggle-group">
            <label class="toggle-switch">
              <input type="checkbox" id="material-favorite" />
              <span class="slider"></span>
              <span class="toggle-label">Bookmark (Favorite)</span>
            </label>

            <label class="toggle-switch">
              <input type="checkbox" id="material-pinned" />
              <span class="slider"></span>
              <span class="toggle-label">Pin to Dashboard</span>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .creator-wrapper {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .creator-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--card-border);
      padding-bottom: 12px;
    }

    .header-left {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
    }

    .back-link:hover {
      color: var(--accent-primary);
    }

    .header-left h2 {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .sharing-form-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 20px;
    }

    .main-form-pane {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .meta-form-pane {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .meta-form-pane h3 {
      font-size: 1.1rem;
      font-weight: 700;
      border-bottom: 1px solid var(--card-border);
      padding-bottom: 8px;
    }

    .meta-inputs-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .title-field-input {
      font-size: 1.15rem;
      font-weight: 600;
      padding: 12px 16px;
    }

    /* Share Type Section */
    .share-type-section {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .section-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .share-type-tabs {
      display: flex;
      background: var(--bg-secondary);
      border: 1px solid var(--card-border);
      padding: 4px;
      border-radius: var(--border-radius-md);
      gap: 4px;
    }

    .type-tab {
      flex: 1;
      padding: 10px;
      font-size: 0.85rem;
      font-weight: 600;
      border-radius: var(--border-radius-sm);
      cursor: pointer;
      color: var(--text-secondary);
      transition: background var(--transition-fast), color var(--transition-fast);
      text-align: center;
    }

    .type-tab.active {
      background: var(--card-bg);
      color: var(--text-primary);
      box-shadow: var(--shadow-sm);
    }

    .type-container {
      width: 100%;
      min-height: 180px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .type-container.hidden {
      display: none;
    }

    /* Upload Zone */
    .upload-dropzone {
      border: 2px dashed var(--card-border);
      border-radius: var(--border-radius-md);
      padding: 36px 20px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      background: var(--bg-secondary);
      transition: border-color var(--transition-fast), background var(--transition-fast);
      position: relative;
      cursor: pointer;
    }

    .upload-dropzone:hover, .upload-dropzone.dragover {
      border-color: var(--accent-primary);
      background: var(--accent-glow);
    }

    .upload-icon {
      color: var(--text-muted);
    }

    .upload-title {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text-secondary);
    }

    .upload-subtext {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .btn-sm {
      padding: 6px 12px;
      font-size: 0.8rem;
      margin-top: 4px;
    }

    .hidden-file-input {
      display: none;
    }

    /* Upload Progress Card */
    .upload-progress-card {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px;
      background: var(--bg-secondary);
      border: 1px solid var(--card-border);
      border-radius: var(--border-radius-md);
      position: relative;
    }

    .upload-progress-card.hidden {
      display: none;
    }

    .file-icon {
      font-size: 1.8rem;
      flex-shrink: 0;
    }

    .file-details {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
    }

    .file-name-label {
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .file-size-label {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .progress-bar-track {
      width: 100%;
      height: 4px;
      background: var(--bg-tertiary);
      border-radius: var(--border-radius-full);
      overflow: hidden;
    }

    .progress-bar-fill {
      height: 100%;
      width: 0;
      background: var(--accent-primary);
      transition: width 0.15s ease;
    }

    .remove-file-btn {
      font-size: 1.5rem;
      color: var(--text-muted);
      cursor: pointer;
      padding: 0 8px;
    }

    .remove-file-btn:hover {
      color: var(--danger);
    }

    .helper-text {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 4px;
    }

    .divider {
      width: 100%;
      height: 1px;
      background: var(--card-border);
      margin: 8px 0;
    }

    /* Toggle switches */
    .toggle-group {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .toggle-switch {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }

    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
      position: absolute;
    }

    .slider {
      position: relative;
      width: 34px;
      height: 18px;
      background-color: var(--bg-tertiary);
      border: 1px solid var(--card-border);
      transition: .25s;
      border-radius: 20px;
      flex-shrink: 0;
    }

    .slider:before {
      position: absolute;
      content: "";
      height: 10px;
      width: 10px;
      left: 3px;
      bottom: 3px;
      background-color: var(--text-muted);
      transition: .25s;
      border-radius: 50%;
    }

    .toggle-switch input:checked + .slider {
      background-color: var(--accent-primary);
    }

    .toggle-switch input:checked + .slider:before {
      transform: translateX(16px);
      background-color: white;
    }

    .toggle-label {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text-secondary);
    }

    .col-span-8 { grid-column: span 8; }
    .col-span-4 { grid-column: span 4; }

    @media (max-width: 1024px) {
      .col-span-8 { grid-column: span 12; }
      .col-span-4 { grid-column: span 12; }
    }
  </style>

  <script>
    // Client-side state manager
    let resourceType: 'file' | 'link' = 'file';
    let uploadedFileId: string | null = null;
    let uploadedFilenameText = '';
    let uploadedFileMime = '';

    // Generate browser-side UUID to link files and note containers asynchronously
    const generatedNoteId = crypto.randomUUID();

    // Tab switches
    const tabFileBtn = document.getElementById('tab-file-btn');
    const tabLinkBtn = document.getElementById('tab-link-btn');
    const fileUploadContainer = document.getElementById('file-upload-container');
    const urlShareContainer = document.getElementById('url-share-container');

    tabFileBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      resourceType = 'file';
      tabFileBtn.classList.add('active');
      tabLinkBtn?.classList.remove('active');
      fileUploadContainer?.classList.remove('hidden');
      urlShareContainer?.classList.add('hidden');
    });

    tabLinkBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      resourceType = 'link';
      tabLinkBtn.classList.add('active');
      tabFileBtn?.classList.remove('active');
      urlShareContainer?.classList.remove('hidden');
      fileUploadContainer?.classList.add('hidden');
    });

    // Upload Dropzone selectors
    const uploadDropzone = document.getElementById('upload-dropzone');
    const browseFilesBtn = document.getElementById('browse-files-btn');
    const fileUploaderInput = document.getElementById('file-uploader-input') as HTMLInputElement;

    const uploadProgressCard = document.getElementById('upload-progress-card');
    const uploadedFilename = document.getElementById('uploaded-filename');
    const uploadedFilesize = document.getElementById('uploaded-filesize');
    const uploadProgressFill = document.getElementById('upload-progress-fill');
    const removeUploadedFileBtn = document.getElementById('remove-uploaded-file-btn');
    
    const materialTitle = document.getElementById('material-title') as HTMLInputElement;

    // Trigger browse
    browseFilesBtn?.addEventListener('click', () => {
      fileUploaderInput.click();
    });

    uploadDropzone?.addEventListener('click', (e) => {
      if (e.target !== browseFilesBtn) {
        fileUploaderInput.click();
      }
    });

    // Drag events
    uploadDropzone?.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadDropzone.classList.add('dragover');
    });

    uploadDropzone?.addEventListener('dragleave', () => {
      uploadDropzone.classList.remove('dragover');
    });

    uploadDropzone?.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadDropzone.classList.remove('dragover');
      const files = e.dataTransfer?.files;
      if (files) handleFileUpload(files[0]);
    });

    fileUploaderInput?.addEventListener('change', () => {
      const files = fileUploaderInput.files;
      if (files) handleFileUpload(files[0]);
    });

    // File upload logic
    const handleFileUpload = async (file: File) => {
      if (!file) return;

      const formatBytesLocal = (bytes: number) => {
        if (bytes === 0) return '0 B';
        const k = 1024;
        const sizes = ['B', 'KB', 'MB', 'GB'];
        const i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
      };

      // Fill in title field with file name if it's currently empty
      if (!materialTitle.value.trim()) {
        const cleanName = file.name.substring(0, file.name.lastIndexOf('.')) || file.name;
        materialTitle.value = cleanName.replace(/[-_]/g, ' ');
      }

      // Display progress panel
      uploadDropzone!.classList.add('hidden');
      uploadProgressCard!.classList.remove('hidden');
      uploadedFilename!.textContent = file.name;
      uploadedFilesize!.textContent = formatBytesLocal(file.size);
      uploadProgressFill!.style.width = '15%';

      const formData = new FormData();
      formData.append('file', file);
      formData.append('noteId', generatedNoteId);

      try {
        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/api/upload', true);

        // Upload progress listener
        xhr.upload.onprogress = (e) => {
          if (e.lengthComputable) {
            const percent = Math.round((e.loaded / e.total) * 100);
            uploadProgressFill!.style.width = `${percent}%`;
          }
        };

        xhr.onload = () => {
          if (xhr.status === 201) {
            const data = JSON.parse(xhr.responseText);
            uploadedFileId = data.attachment.id;
            uploadedFilenameText = data.attachment.filename;
            uploadedFileMime = data.attachment.mime_type;
            uploadProgressFill!.style.width = '100%';
            uploadProgressFill!.style.backgroundColor = 'var(--success)';
          } else {
            const data = JSON.parse(xhr.responseText);
            alert(`Upload failed: ${data.error}`);
            resetUploadZone();
          }
        };

        xhr.onerror = () => {
          alert('Upload failed due to connection error.');
          resetUploadZone();
        };

        xhr.send(formData);
      } catch (err) {
        console.error(err);
        resetUploadZone();
      }
    };

    const resetUploadZone = () => {
      uploadedFileId = null;
      uploadProgressCard?.classList.add('hidden');
      uploadDropzone?.classList.remove('hidden');
      fileUploaderInput.value = '';
    };

    removeUploadedFileBtn?.addEventListener('click', async (e) => {
      e.stopPropagation();
      if (uploadedFileId) {
        try {
          const res = await fetch(`/api/files/${uploadedFileId}`, { method: 'DELETE' });
          if (res.ok) {
            resetUploadZone();
          } else {
            alert('Failed to remove uploaded file');
          }
        } catch (err) {
          console.error(err);
        }
      } else {
        resetUploadZone();
      }
    });

    // Save Material submission
    const saveMaterialBtn = document.getElementById('save-material-btn');
    saveMaterialBtn?.addEventListener('click', async (e) => {
      e.preventDefault();

      const title = materialTitle.value.trim();
      const description = (document.getElementById('material-description') as HTMLTextAreaElement).value;
      const collectionId = (document.getElementById('material-collection') as HTMLSelectElement).value || null;
      const category = (document.getElementById('material-category') as HTMLInputElement).value.trim();
      const semester = (document.getElementById('material-semester') as HTMLInputElement).value.trim();
      const topic = (document.getElementById('material-topic') as HTMLInputElement).value.trim();
      const tagsString = (document.getElementById('material-tags') as HTMLInputElement).value;
      const isFavorite = (document.getElementById('material-favorite') as HTMLInputElement).checked;
      const isPinned = (document.getElementById('material-pinned') as HTMLInputElement).checked;

      if (!title) {
        alert('Resource Title is required.');
        return;
      }

      if (resourceType === 'file' && !uploadedFileId) {
        alert('Please drop or select a file to upload first.');
        return;
      }

      let shareUrl = '';
      if (resourceType === 'link') {
        shareUrl = (document.getElementById('material-url') as HTMLInputElement).value.trim();
        if (!shareUrl) {
          alert('Please enter the URL link.');
          return;
        }
      }

      // Convert tags
      const tags = tagsString
        .split(',')
        .map((t) => t.trim())
        .filter((t) => t.length > 0);

      // Construct markdown note body representing the content.
      // If it is a file upload: we represent it in note content as standard text description
      // If it is a URL link: we embed the naked URL in the note body, which the link synchronizer automatically extracts!
      let noteBody = description || '';
      if (resourceType === 'link') {
        noteBody = `${shareUrl}\n\n${noteBody}`;
      }

      try {
        saveMaterialBtn.setAttribute('disabled', 'true');
        saveMaterialBtn.textContent = 'Saving Resource...';

        const res = await fetch('/api/notes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: generatedNoteId, // Bind the same ID used in file uploading!
            title,
            content: noteBody,
            collection_id: collectionId,
            category: category || 'General',
            semester: semester || 'All',
            topic: topic || 'General',
            is_favorite: isFavorite,
            is_pinned: isPinned,
            tags,
          }),
        });

        const data = await res.json();

        if (res.ok) {
          window.location.href = `/notes/${generatedNoteId}`;
        } else {
          alert(data.error || 'Failed to share material');
          saveMaterialBtn.removeAttribute('disabled');
          saveMaterialBtn.textContent = 'Share Resource';
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred during submission.');
        saveMaterialBtn.removeAttribute('disabled');
        saveMaterialBtn.textContent = 'Share Resource';
      }
    });
  </script>
</Layout>
