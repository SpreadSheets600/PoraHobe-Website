---
import AuthLayout from '../layouts/AuthLayout.astro';
import { env } from 'cloudflare:workers';
import BentoCard from '../components/BentoCard.astro';

const inviteOnly = env.INVITE_ONLY === 'true';
const turnstileSiteKey = env.TURNSTILE_SITE_KEY || '1x00000000000000000000AA';
---

<AuthLayout title="Login - PoraHobe">
  <div class="min-h-screen w-full flex items-center justify-center bg-[radial-gradient(circle_at_center,var(--bg-secondary)_0%,var(--bg-primary)_100%)] p-5">
    <BentoCard class="w-[400px] max-w-full text-center flex flex-col gap-6 shadow-[var(--shadow-lg),var(--shadow-glow)]">
      <div>
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-[var(--accent-primary)]">
          <path d="m16 6 4 14H4L8 6z"></path>
          <path d="M12 2v4"></path>
        </svg>
        <h1 class="text-[1.75rem] font-bold tracking-tight">PoraHobe</h1>
        <p class="text-sm text-[var(--text-muted)]">Private Notes & Study Material Platform</p>
      </div>

      <div class="flex bg-[var(--bg-tertiary)] p-1 rounded-[var(--border-radius-md)] border border-[var(--card-border)]">
        <button class="tab-trigger flex-1 py-2 rounded-lg font-semibold text-sm cursor-pointer text-[var(--text-secondary)] transition-all duration-[var(--transition-fast)] bg-[var(--card-bg)] text-[var(--text-primary)] shadow-[var(--shadow-sm)]" id="tab-login-btn">Login</button>
        <button class="tab-trigger flex-1 py-2 rounded-lg font-semibold text-sm cursor-pointer text-[var(--text-secondary)] transition-all duration-[var(--transition-fast)]" id="tab-register-btn">Register</button>
      </div>

      <div class="flex flex-col gap-4">
        <form id="login-form" class="flex flex-col gap-4 text-left">
          <div class="flex flex-col gap-1.5">
            <label for="login-username" class="text-sm font-medium text-[var(--text-secondary)]">Username</label>
            <input type="text" id="login-username" name="username" placeholder="e.g., student" required class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="login-password" class="text-sm font-medium text-[var(--text-secondary)]">Password</label>
            <input type="password" id="login-password" name="password" placeholder="••••••••" required class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" />
          </div>
          <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-[18px] py-3 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] hover:-translate-y-px">Sign In</button>
        </form>

        <form id="register-form" class="flex flex-col gap-4 text-left hidden">
          <div class="flex flex-col gap-1.5">
            <label for="register-username" class="text-sm font-medium text-[var(--text-secondary)]">Username</label>
            <input type="text" id="register-username" name="username" placeholder="Min. 3 characters" required class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="register-password" class="text-sm font-medium text-[var(--text-secondary)]">Password</label>
            <input type="password" id="register-password" name="password" placeholder="Min. 6 characters" required class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" />
          </div>
          {inviteOnly && (
            <div class="flex flex-col gap-1.5">
              <label for="register-invite" class="text-sm font-medium text-[var(--text-secondary)]">Invite Code</label>
              <input type="text" id="register-invite" name="inviteCode" placeholder="Enter private invite code" required class="w-full bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] px-3.5 py-2.5 text-sm text-[var(--text-primary)] transition-colors duration-[var(--transition-fast)] focus:border-[var(--accent-primary)] focus:bg-[var(--bg-primary)] focus:shadow-[0_0_0_3px_var(--accent-glow)]" />
            </div>
          )}
          <div class="flex justify-center my-2">
            <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
          </div>
          <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-[18px] py-3 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-transparent transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_8px_rgba(139,92,246,0.2)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] hover:-translate-y-px">Create Account</button>
        </form>
      </div>

      <div id="error-message" class="hidden text-left px-3 py-3 rounded-[var(--border-radius-md)] text-sm bg-[hsla(347,77%,50%,0.15)] border border-[hsla(347,77%,50%,0.3)] text-[var(--danger)]"></div>
      <div id="success-message" class="hidden text-left px-3 py-3 rounded-[var(--border-radius-md)] text-sm bg-[hsla(142,76%,36%,0.15)] border border-[hsla(142,76%,36%,0.3)] text-[var(--success)]"></div>
    </BentoCard>
  </div>

  <style>
    .tab-active {
      background: var(--card-bg);
      color: var(--text-primary);
      box-shadow: var(--shadow-sm);
    }
  </style>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <script>
    const tabLoginBtn = document.getElementById('tab-login-btn');
    const tabRegisterBtn = document.getElementById('tab-register-btn');
    const loginForm = document.getElementById('login-form');
    const registerForm = document.getElementById('register-form');
    const errorAlert = document.getElementById('error-message');
    const successAlert = document.getElementById('success-message');

    const clearAlerts = () => { errorAlert?.classList.add('hidden'); successAlert?.classList.add('hidden'); };
    const showError = (msg) => { errorAlert!.textContent = msg; errorAlert?.classList.remove('hidden'); };
    const showSuccess = (msg) => { successAlert!.textContent = msg; successAlert?.classList.remove('hidden'); };

    const setActiveTab = (active: HTMLElement, inactive: HTMLElement, show: HTMLElement, hide: HTMLElement) => {
      active.classList.add('tab-active');
      inactive.classList.remove('tab-active');
      show.classList.remove('hidden'); hide.classList.add('hidden');
      clearAlerts();
    };

    tabLoginBtn?.addEventListener('click', () => setActiveTab(tabLoginBtn, tabRegisterBtn!, loginForm!, registerForm!));
    tabRegisterBtn?.addEventListener('click', () => setActiveTab(tabRegisterBtn, tabLoginBtn!, registerForm!, loginForm!));

    loginForm?.addEventListener('submit', async (e) => {
      e.preventDefault(); clearAlerts();
      const username = (document.getElementById('login-username') as HTMLInputElement).value;
      const password = (document.getElementById('login-password') as HTMLInputElement).value;
      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });
        const data = await res.json();
        if (res.ok) { showSuccess('Signed in successfully! Redirecting...'); setTimeout(() => window.location.href = '/', 1000); }
        else showError(data.error || 'Authentication failed');
      } catch { showError('An error occurred during sign in.'); }
    });

    registerForm?.addEventListener('submit', async (e) => {
      e.preventDefault(); clearAlerts();
      const username = (document.getElementById('register-username') as HTMLInputElement).value;
      const password = (document.getElementById('register-password') as HTMLInputElement).value;
      const inviteInput = document.getElementById('register-invite') as HTMLInputElement;
      const turnstileResponse = (registerForm.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement)?.value;
      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password, inviteCode: inviteInput?.value || undefined, turnstileToken: turnstileResponse || undefined }),
        });
        const data = await res.json();
        if (res.ok) { showSuccess('Account created successfully! Redirecting...'); setTimeout(() => window.location.href = '/', 1000); }
        else showError(data.error || 'Registration failed');
      } catch { showError('An error occurred during registration.'); }
    });
  </script>
  </AuthLayout>
