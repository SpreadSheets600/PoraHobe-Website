---
interface Props {
  class?: string;
  interactive?: boolean;
  padding?: boolean;
}

const { class: className, interactive = false, padding = true } = Astro.props;
---

<div
  class:list={[
    "bg-[var(--card-bg)] border border-[var(--card-border)] rounded-[var(--border-radius-lg)] backdrop-blur-[16px] shadow-[var(--shadow-sm)] transition-all duration-[var(--transition-normal)] relative overflow-hidden",
    padding && "p-6",
    interactive && "hover:-translate-y-0.5 hover:shadow-[var(--shadow-lg),var(--shadow-glow)] hover:border-[hsla(262,83%,58%,0.35)] cursor-pointer",
    className,
  ]}
>
  <slot />
</div>
