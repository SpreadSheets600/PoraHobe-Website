---
import { buildCollectionTree } from "../utils/db";
import type { Collection } from "../utils/db";
import { env } from "cloudflare:workers";
import "../styles/global.css";
import Icon from "../components/Icon.astro";

interface Props {
	title?: string;
}

const { title = "PoraHobe - Notes & Study Material Platform" } = Astro.props;
const user = Astro.locals.user;
const db = env.DB;

let collections: Collection[] = [];
if (db && user) {
	try {
		const { results } = await db.prepare("SELECT * FROM collections WHERE user_id = ? ORDER BY name ASC").bind(user.id).all<Collection>();
		collections = buildCollectionTree(results);
	} catch (e) {
		console.error("Failed to load collections in layout:", e);
	}
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#8b5cf6" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css" integrity="sha384-GvrOXuhMATgEsSwCs4smul74iXGOixntILdUW9XmUC6+HX0sLNAK3q71HotJqlAn" crossorigin="anonymous" />
		<script is:inline>
			const getTheme = () => {
				if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
					return localStorage.getItem("theme");
				}
				return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
			};
			const theme = getTheme();
			if (theme === "dark") document.documentElement.classList.add("dark");
			else document.documentElement.classList.remove("dark");
			if ("serviceWorker" in navigator) {
				window.addEventListener("load", () => {
					navigator.serviceWorker.register("/sw.js").catch((err) => console.error("PWA registration failed:", err));
				});
			}
		</script>
	</head>
	<body class="font-[Outfit,sans-serif] text-[15px] antialiased">
		<div class="flex w-screen h-screen overflow-hidden">
			{
				user && (
					<aside id="sidebar" class="w-[260px] min-w-[260px] h-full bg-[var(--bg-secondary)] border-r border-[var(--card-border)] flex flex-col z-100 transition-transform duration-[var(--transition-normal)] max-md:fixed max-md:left-0 max-md:top-0 max-md:bottom-0 max-md:-translate-x-full max-md:shadow-[var(--shadow-lg)] max-md:data-[open=true]:translate-x-0">
						<div class="p-6 flex items-center justify-between">
							<a href="/" class="flex items-center gap-3 font-bold text-xl tracking-tight text-[var(--accent-primary)]">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<>
										<path d="m16 6 4 14H4L8 6z" />
										<path d="M12 2v4" />
									</>
								</svg>
								<span>PoraHobe</span>
							</a>
							<button id="mobile-close-btn" class="hidden max-md:block cursor-pointer text-[var(--text-muted)]" aria-label="Close menu">
								<Icon name="close" size={20} />
							</button>
						</div>

						<div class="mx-4 mb-4 p-3 bg-[var(--card-bg)] border border-[var(--card-border)] rounded-[var(--border-radius-md)] flex items-center gap-3">
							<img src={`https://api.dicebear.com/9.x/lorelei/png?seed=${user.username}`} class="w-9 h-9 bg-[var(--bg-tertiary)] border-[1.5px] border-[var(--accent-primary)] p-0.5 rounded-full object-cover block" alt={user.username} />
							<div class="flex-1 flex flex-col min-w-0">
								<span class="font-medium text-sm text-[var(--text-primary)] truncate">{user.username}</span>
								<span class="text-xs text-[var(--text-muted)] capitalize">{user.role}</span>
							</div>
							<button id="logout-btn" title="Sign out" class="text-[var(--text-muted)] cursor-pointer p-1 rounded-[var(--border-radius-sm)] transition-colors duration-[var(--transition-fast)] hover:text-[var(--danger)]">
								<Icon name="logout" size={18} />
							</button>
						</div>

						<nav class="flex-1 overflow-y-auto px-4 flex flex-col gap-1">
							<a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-[var(--border-radius-md)] font-medium text-sm text-[var(--text-secondary)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]">
								<Icon name="grid" size={18} />
								<span>Dashboard</span>
							</a>
							<a href="/notes" class="flex items-center gap-3 px-3 py-2.5 rounded-[var(--border-radius-md)] font-medium text-sm text-[var(--text-secondary)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]">
								<Icon name="edit" size={18} />
								<span>All Materials</span>
							</a>
							<a href="/notes?is_favorite=1" class="flex items-center gap-3 px-3 py-2.5 rounded-[var(--border-radius-md)] font-medium text-sm text-[var(--text-secondary)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]">
								<Icon name="bookmark" size={18} />
								<span>Bookmarks</span>
							</a>

							<div class="flex items-center justify-between mt-6 mb-2 px-3 text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wider">
								<span>Folders</span>
								<button id="create-folder-btn" title="Add Folder" class="text-[var(--text-muted)] cursor-pointer p-0.5 rounded-sm flex items-center justify-center hover:text-[var(--accent-primary)] hover:bg-[var(--bg-tertiary)]">
									<Icon name="plus" size={14} />
								</button>
							</div>

							<div id="collections-tree" class="flex flex-col gap-1">
								{collections.length === 0 ?
									<div class="text-sm text-[var(--text-muted)] px-3 py-2 italic">No folders created.</div>
								:	<ul class="flex flex-col gap-0.5 list-none">
										{collections.map((folder) => (
											<li class="tree-item flex flex-col" data-folder-id={folder.id}>
												<div class="flex items-center gap-1 px-2 py-1.5 rounded-[var(--border-radius-sm)] transition-colors duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] group">
													<span class="w-4 h-4 flex items-center justify-center cursor-pointer text-[var(--text-muted)] hover:text-[var(--text-primary)]">
														{folder.children && folder.children.length > 0 ?
															<svg class="tree-chevron transition-transform duration-[var(--transition-fast)]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
																<path d="m9 18 6-6-6-6" />
															</svg>
														:	<span class="w-1 h-1 bg-[var(--text-muted)] rounded-full block" />}
													</span>
													<a href={`/notes?collection_id=${folder.id}`} class="flex-1 flex items-center gap-2 text-sm font-medium text-[var(--text-secondary)] min-w-0">
														<Icon name="folder" size={16} />
														<span class="truncate">{folder.name}</span>
													</a>
													<button class="delete-folder-btn-inline opacity-0 group-hover:opacity-100 cursor-pointer p-0.5 rounded-[var(--border-radius-sm)] flex items-center justify-center text-[var(--text-muted)] transition-all duration-[var(--transition-fast)] hover:text-[var(--danger)] hover:bg-[var(--bg-secondary)]" data-folder-id={folder.id} title="Delete folder">
														<Icon name="trash" size={12} />
													</button>
												</div>
												{folder.children && folder.children.length > 0 && (
													<ul class="ml-4 border-l border-dashed border-[var(--card-border)] pl-2 mt-0.5 flex flex-col gap-0.5 list-none">
														{folder.children.map((child) => (
															<li class="tree-item flex flex-col" data-folder-id={child.id}>
																<div class="flex items-center gap-1 px-2 py-1.5 rounded-[var(--border-radius-sm)] transition-colors duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] group">
																	<span class="w-1 h-1 bg-[var(--text-muted)] rounded-full block mx-1.5" />
																	<a href={`/notes?collection_id=${child.id}`} class="flex-1 flex items-center gap-2 text-sm font-medium text-[var(--text-secondary)] min-w-0">
																		<Icon name="folder" size={14} />
																		<span class="truncate">{child.name}</span>
																	</a>
																	<button class="delete-folder-btn-inline opacity-0 group-hover:opacity-100 cursor-pointer p-0.5 rounded-[var(--border-radius-sm)] flex items-center justify-center text-[var(--text-muted)] transition-all duration-[var(--transition-fast)] hover:text-[var(--danger)] hover:bg-[var(--bg-secondary)]" data-folder-id={child.id} title="Delete folder">
																		<Icon name="trash" size={11} />
																	</button>
																</div>
															</li>
														))}
													</ul>
												)}
											</li>
										))}
									</ul>
								}
							</div>
						</nav>

						<div class="p-4 border-t border-[var(--card-border)] flex flex-col gap-1.5">
							<button id="theme-toggle-btn" title="Toggle Theme" class="flex items-center gap-3 px-3 py-2 w-full text-sm font-medium text-[var(--text-secondary)] cursor-pointer rounded-[var(--border-radius-md)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]">
								<Icon name="sun" size={18} class="hidden dark:block" />
								<Icon name="moon" size={18} class="block dark:hidden" />
								<span>Appearance</span>
							</button>
							<button id="shortcuts-btn" title="Keyboard Shortcuts" class="flex items-center gap-3 px-3 py-2 w-full text-sm font-medium text-[var(--text-secondary)] cursor-pointer rounded-[var(--border-radius-md)] transition-all duration-[var(--transition-fast)] hover:bg-[var(--bg-tertiary)] hover:text-[var(--text-primary)]">
								<Icon name="key" size={18} />
								<span>Shortcuts</span>
							</button>
						</div>
					</aside>
				)
			}

			<div class="flex-1 flex flex-col h-full overflow-hidden">
				{
					user && (
						<header class="h-16 border-b border-[var(--card-border)] px-8 max-md:px-4 flex items-center justify-between gap-6 bg-[var(--bg-primary)] z-10">
							<button id="mobile-open-btn" class="hidden max-md:block cursor-pointer text-[var(--text-secondary)]" aria-label="Open menu">
								<Icon name="menu" size={24} />
							</button>

							<div class="flex items-center gap-2.5 bg-[var(--bg-secondary)] border border-[var(--card-border)] rounded-[var(--border-radius-full)] px-4 py-2 w-[320px] max-md:w-[180px] transition-all duration-[var(--transition-normal)] focus-within:w-[440px] max-md:focus-within:w-[240px] focus-within:border-[var(--accent-primary)]">
								<Icon name="search" size={18} class="text-[var(--text-muted)] flex-shrink-0" />
								<input type="text" id="global-search" placeholder="Search notes, tags, or links... (Press '/')" autocomplete="off" class="flex-1 text-sm text-[var(--text-primary)] placeholder:text-[var(--text-muted)] bg-transparent border-none outline-none" />
								<span class="font-mono text-xs px-1.5 py-0.5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] rounded text-[var(--text-muted)] shadow-[0_1px_0_rgba(0,0,0,0.1)]">/</span>
							</div>

							<div class="flex items-center gap-2">
								<a href="/notes/new" class="inline-flex items-center gap-2 px-4 py-2 rounded-[var(--border-radius-full)] font-semibold text-sm cursor-pointer transition-all duration-[var(--transition-fast)] bg-[var(--accent-primary)] text-white shadow-[0_2px_4px_rgba(139,92,246,0.15)] hover:bg-[var(--accent-hover)] hover:shadow-[0_4px_8px_rgba(139,92,246,0.25)] max-md:p-2">
									<Icon name="plus" size={16} />
									<span class="max-md:hidden">Share Material</span>
								</a>
							</div>
						</header>
					)
				}

				<main class="flex-1 overflow-y-auto p-8 max-md:p-4 bg-[var(--bg-primary)]">
					<slot />
				</main>
			</div>
		</div>

		<div id="shortcuts-modal" class="fixed inset-0 bg-black/60 backdrop-blur-[8px] flex items-center justify-center z-1000 transition-opacity duration-[var(--transition-normal)] hidden opacity-0 pointer-events-none">
			<div class="w-[420px] max-w-[90%] flex flex-col gap-5 bg-[var(--card-bg)] border border-[var(--card-border)] rounded-[var(--border-radius-lg)] p-6 backdrop-blur-[16px] shadow-[var(--shadow-sm)] animate-[scaleUp_0.3s_cubic-bezier(0.16,1,0.3,1)_forwards]">
				<h3 class="text-xl font-semibold">Keyboard Shortcuts</h3>
				<ul class="flex flex-col gap-3 list-none">
					<li class="flex items-center gap-3 text-sm text-[var(--text-secondary)]"><span class="font-mono text-xs px-1.5 py-0.5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] rounded text-[var(--text-muted)] shadow-[0_1px_0_rgba(0,0,0,0.1)]">/</span> Global Search focus</li>
					<li class="flex items-center gap-3 text-sm text-[var(--text-secondary)]"><span class="font-mono text-xs px-1.5 py-0.5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] rounded text-[var(--text-muted)] shadow-[0_1px_0_rgba(0,0,0,0.1)]">N</span> Create a new note</li>
					<li class="flex items-center gap-3 text-sm text-[var(--text-secondary)]"><span class="font-mono text-xs px-1.5 py-0.5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] rounded text-[var(--text-muted)] shadow-[0_1px_0_rgba(0,0,0,0.1)]">Esc</span> Close search/modals</li>
					<li class="flex items-center gap-3 text-sm text-[var(--text-secondary)]"><span class="font-mono text-xs px-1.5 py-0.5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] rounded text-[var(--text-muted)] shadow-[0_1px_0_rgba(0,0,0,0.1)]">D</span> Go to dashboard</li>
					<li class="flex items-center gap-3 text-sm text-[var(--text-secondary)]"><span class="font-mono text-xs px-1.5 py-0.5 bg-[var(--bg-tertiary)] border border-[var(--card-border)] rounded text-[var(--text-muted)] shadow-[0_1px_0_rgba(0,0,0,0.1)]">A</span> View all notes</li>
				</ul>
				<button id="close-shortcuts-btn" class="inline-flex items-center justify-center gap-2 px-[18px] py-2.5 rounded-[var(--border-radius-md)] font-semibold text-sm cursor-pointer border border-[var(--card-border)] transition-all duration-[var(--transition-fast)] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:border-[var(--text-muted)] hover:text-[var(--text-primary)] hover:-translate-y-px">Close</button>
			</div>
		</div>

		<script>
			// Theme toggler
			const themeToggleBtn = document.getElementById("theme-toggle-btn");
			if (themeToggleBtn) {
				themeToggleBtn.addEventListener("click", () => {
					const isDark = document.documentElement.classList.toggle("dark");
					localStorage.setItem("theme", isDark ? "dark" : "light");
				});
			}

			// Logout handler
			const logoutBtn = document.getElementById("logout-btn");
			if (logoutBtn) {
				logoutBtn.addEventListener("click", async () => {
					if (confirm("Are you sure you want to sign out?")) {
						try {
							const res = await fetch("/api/auth/logout", { method: "POST" });
							if (res.ok) window.location.href = "/login";
						} catch (e) {
							console.error("Logout error:", e);
						}
					}
				});
			}

			// Add folder
			const addFolderBtn = document.getElementById("create-folder-btn");
			if (addFolderBtn) {
				addFolderBtn.addEventListener("click", async (e) => {
					e.stopPropagation();
					const folderName = prompt("Enter new folder name:");
					if (folderName && folderName.trim()) {
						try {
							const res = await fetch("/api/collections", {
								method: "POST",
								headers: { "Content-Type": "application/json" },
								body: JSON.stringify({ name: folderName.trim() }),
							});
							if (res.ok) window.location.reload();
							else {
								const data = await res.json();
								alert(data.error || "Failed to create folder");
							}
						} catch (err) {
							console.error(err);
						}
					}
				});
			}

			// Delete folder
			document.querySelectorAll(".delete-folder-btn-inline").forEach((btn) => {
				btn.addEventListener("click", async (e) => {
					e.preventDefault();
					e.stopPropagation();
					const folderId = btn.getAttribute("data-folder-id");
					if (!folderId) return;
					if (confirm("Are you sure you want to delete this folder? Any sub-folders will also be deleted.")) {
						try {
							const res = await fetch("/api/collections", {
								method: "DELETE",
								headers: { "Content-Type": "application/json" },
								body: JSON.stringify({ id: folderId }),
							});
							if (res.ok) {
								const urlParams = new URLSearchParams(window.location.search);
								const currentCollectionId = urlParams.get("collection_id");
								if (currentCollectionId === folderId) window.location.href = "/notes";
								else window.location.reload();
							} else {
								const data = await res.json();
								alert(data.error || "Failed to delete folder");
							}
						} catch (err) {
							console.error("Delete folder error:", err);
							alert("An error occurred while deleting the folder.");
						}
					}
				});
			});

			// Mobile sidebar toggle
			const mobileOpenBtn = document.getElementById("mobile-open-btn");
			const mobileCloseBtn = document.getElementById("mobile-close-btn");
			const sidebar = document.getElementById("sidebar");

			if (mobileOpenBtn && sidebar) {
				mobileOpenBtn.addEventListener("click", () => sidebar.setAttribute("data-open", "true"));
			}
			if (mobileCloseBtn && sidebar) {
				mobileCloseBtn.addEventListener("click", () => sidebar.removeAttribute("data-open"));
			}

			// Shortcuts modal
			const shortcutsBtn = document.getElementById("shortcuts-btn");
			const shortcutsModal = document.getElementById("shortcuts-modal");
			const closeShortcutsBtn = document.getElementById("close-shortcuts-btn");

			if (shortcutsBtn && shortcutsModal) {
				shortcutsBtn.addEventListener("click", () => shortcutsModal.classList.remove("hidden", "opacity-0", "pointer-events-none"));
				const closeModal = () => shortcutsModal.classList.add("hidden", "opacity-0", "pointer-events-none");
				closeShortcutsBtn?.addEventListener("click", closeModal);
				shortcutsModal.addEventListener("click", (e) => {
					if (e.target === shortcutsModal) closeModal();
				});
			}

			// Global search keyboard shortcut
			const globalSearch = document.getElementById("global-search");
			document.addEventListener("keydown", (e) => {
				if (e.key === "/" && !["INPUT", "TEXTAREA"].includes((e.target as HTMLElement).tagName)) {
					e.preventDefault();
					globalSearch?.focus();
				}
				if (e.key === "Escape") globalSearch?.blur();
				if (e.key === "n" && !["INPUT", "TEXTAREA"].includes((e.target as HTMLElement).tagName)) {
					e.preventDefault();
					window.location.href = "/notes/new";
				}
				if (e.key === "d" && !["INPUT", "TEXTAREA"].includes((e.target as HTMLElement).tagName)) {
					e.preventDefault();
					window.location.href = "/";
				}
				if (e.key === "a" && !["INPUT", "TEXTAREA"].includes((e.target as HTMLElement).tagName)) {
					e.preventDefault();
					window.location.href = "/notes";
				}
			});

			// Collection tree collapse/expand
			document.querySelectorAll(".tree-item").forEach((item) => {
				const chevron = item.querySelector(".tree-chevron");
				if (chevron) {
					item.classList.add("expanded");
					chevron.addEventListener("click", (e) => {
						e.stopPropagation();
						item.classList.toggle("expanded");
					});
				}
			});
		</script>

		<style is:global>
			.tree-item:not(.expanded) > ul {
				display: none;
			}
			.tree-item.expanded > div .tree-chevron {
				transform: rotate(90deg);
			}
		</style>
	</body>
</html>
